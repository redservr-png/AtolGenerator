<UserControl x:Class="AtolGenerator.Views.ObsidianCasesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cv="clr-namespace:AtolGenerator.Views.Converters"
             Background="{DynamicResource BrushBg}">
  <UserControl.Resources>
    <cv:BoolToVisibilityConverter x:Key="BoolVis"/>
    <cv:CorrectionScenarioLabelConverter x:Key="ScenarioLabel"/>
    <Style x:Key="WorkflowButton" TargetType="Button" BasedOn="{StaticResource BtnSecondary}">
      <Setter Property="MinHeight" Value="36"/>
      <Setter Property="Padding" Value="14,7"/>
      <Setter Property="FontSize" Value="13"/>
    </Style>
    <Style x:Key="SelectableText" TargetType="TextBox">
      <Setter Property="IsReadOnly" Value="True"/>
      <Setter Property="IsReadOnlyCaretVisible" Value="True"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="MinHeight" Value="0"/>
      <Setter Property="Foreground" Value="{DynamicResource BrushText2}"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
      <Setter Property="VerticalContentAlignment" Value="Top"/>
      <Setter Property="Cursor" Value="IBeam"/>
      <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    </Style>
    <Style x:Key="SelectableValue" TargetType="TextBox" BasedOn="{StaticResource SelectableText}">
      <Setter Property="Foreground" Value="{DynamicResource BrushText}"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style x:Key="PeriodComboBox" TargetType="ComboBox"
           BasedOn="{StaticResource {x:Type ComboBox}}">
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ComboBox">
            <Grid>
              <Border x:Name="PeriodBorder"
                      Background="{TemplateBinding Background}"
                      BorderBrush="{TemplateBinding BorderBrush}"
                      BorderThickness="{TemplateBinding BorderThickness}"
                      CornerRadius="6">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="30"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="{Binding DataContext.SelectedPeriod, RelativeSource={RelativeSource TemplatedParent}}"
                             Margin="{TemplateBinding Padding}"
                             VerticalAlignment="Center"
                             Foreground="{TemplateBinding Foreground}"
                             TextTrimming="CharacterEllipsis"/>
                  <TextBlock Grid.Column="1" Text="▾" VerticalAlignment="Center"
                             HorizontalAlignment="Center"
                             Foreground="{DynamicResource BrushText2}" FontSize="12"/>
                  <ToggleButton Grid.ColumnSpan="2" Opacity="0" Focusable="False"
                                IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"/>
                </Grid>
              </Border>
              <Popup x:Name="PART_Popup" IsOpen="{TemplateBinding IsDropDownOpen}"
                     Placement="Bottom" AllowsTransparency="True" Focusable="False"
                     PopupAnimation="Slide">
                <Border Background="{DynamicResource BrushSurface2}"
                        BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                        CornerRadius="6" MinWidth="{TemplateBinding ActualWidth}"
                        MaxHeight="220">
                  <ScrollViewer>
                    <ItemsPresenter/>
                  </ScrollViewer>
                </Border>
              </Popup>
            </Grid>
            <ControlTemplate.Triggers>
              <Trigger Property="IsFocused" Value="True">
                <Setter TargetName="PeriodBorder" Property="BorderBrush"
                        Value="{DynamicResource BrushAccent}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="CaseGrid" TargetType="DataGrid">
      <Setter Property="AutoGenerateColumns" Value="False"/>
      <Setter Property="CanUserAddRows" Value="False"/>
      <Setter Property="CanUserDeleteRows" Value="False"/>
      <Setter Property="CanUserResizeRows" Value="False"/>
      <Setter Property="HeadersVisibility" Value="Column"/>
      <Setter Property="GridLinesVisibility" Value="Horizontal"/>
      <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource BrushBorder}"/>
      <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
      <Setter Property="RowHeaderWidth" Value="0"/>
      <Setter Property="Background" Value="{DynamicResource BrushSurface1}"/>
      <Setter Property="RowBackground" Value="{DynamicResource BrushSurface1}"/>
      <Setter Property="AlternatingRowBackground" Value="{DynamicResource BrushSurface2}"/>
      <Setter Property="Foreground" Value="{DynamicResource BrushText}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="SelectionMode" Value="Extended"/>
      <Setter Property="SelectionUnit" Value="CellOrRowHeader"/>
      <Setter Property="ClipboardCopyMode" Value="IncludeHeader"/>
      <Setter Property="RowHeight" Value="42"/>
      <Setter Property="ColumnHeaderHeight" Value="38"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="HorizontalScrollBarVisibility" Value="Visible"/>
      <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
    </Style>
    <Style TargetType="DataGridColumnHeader">
      <Setter Property="Background" Value="{DynamicResource BrushSurface2}"/>
      <Setter Property="Foreground" Value="{DynamicResource BrushText2}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}"/>
      <Setter Property="BorderThickness" Value="0,0,1,1"/>
      <Setter Property="Padding" Value="8,0"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="HorizontalContentAlignment" Value="Left"/>
    </Style>
    <Style TargetType="DataGridRow">
      <Setter Property="Background" Value="{DynamicResource BrushSurface1}"/>
      <Setter Property="Foreground" Value="{DynamicResource BrushText2}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="{DynamicResource BrushSurface3}"/>
        </Trigger>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="{DynamicResource BrushSurface3}"/>
          <Setter Property="Foreground" Value="{DynamicResource BrushText}"/>
        </Trigger>
      </Style.Triggers>
    </Style>
    <Style TargetType="DataGridCell">
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="7,0"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
      <Style.Triggers>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="{DynamicResource BrushSurface3}"/>
          <Setter Property="Foreground" Value="{DynamicResource BrushText}"/>
        </Trigger>
      </Style.Triggers>
    </Style>
  </UserControl.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="78"/>
      <RowDefinition Height="116"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="36"/>
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="{DynamicResource BrushSurface1}"
            BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,0,0,1">
      <Grid Margin="24,0">
        <StackPanel VerticalAlignment="Center">
          <TextBlock Text="Исправление чеков" FontSize="22" FontWeight="SemiBold"/>
          <TextBlock Text="{Binding FilePath}" Foreground="{DynamicResource BrushText3}"
                     FontSize="11" Margin="0,5,0,0" TextTrimming="CharacterEllipsis"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
          <TextBlock Text="Активных: " Foreground="{DynamicResource BrushText3}"/>
          <TextBlock Text="{Binding ActiveCount, Mode=OneWay}" FontWeight="Bold"/>
          <TextBlock Text="   Закрытых: " Foreground="{DynamicResource BrushText3}"/>
          <TextBlock Text="{Binding ClosedCount, Mode=OneWay}" FontWeight="Bold"/>
        </StackPanel>
      </Grid>
    </Border>

    <Border Grid.Row="1" Background="{DynamicResource BrushSurface2}"
            BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,0,0,1">
      <Grid Margin="24,12">
        <Grid.RowDefinitions>
          <RowDefinition Height="38"/>
          <RowDefinition Height="54"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="240"/>
          <ColumnDefinition Width="12"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="16"/>
          <ColumnDefinition Width="170"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="220"/>
        </Grid.ColumnDefinitions>
        <TextBox Grid.Column="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                 Tag="Поиск по документу или проблеме"/>
        <CheckBox Grid.Column="2" Content="Показывать закрытые" IsChecked="{Binding ShowClosed}"
                  VerticalAlignment="Center"/>
        <ComboBox Grid.Column="4" VerticalAlignment="Center"
                  Style="{StaticResource PeriodComboBox}"
                  ItemsSource="{Binding PeriodOptions}"
                  SelectedItem="{Binding SelectedPeriod, Mode=TwoWay}"/>
        <TextBlock Grid.Column="6" Text="{Binding SourceOfdReportInfo}"
                   Foreground="{DynamicResource BrushText3}" FontSize="11"
                   VerticalAlignment="Center" TextAlignment="Right"
                   TextTrimming="CharacterEllipsis" ToolTip="{Binding SourceOfdReportInfo}"/>
        <Grid Grid.Row="1" Grid.ColumnSpan="7" Margin="0,10,0,0" VerticalAlignment="Center">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="18"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <Button Grid.Column="0" Content="Обновить" Style="{StaticResource WorkflowButton}"
                  Command="{Binding SyncCommand}"/>
          <Button Grid.Column="1" Content="Выбрать видимые" Style="{StaticResource WorkflowButton}"
                  Margin="8,0,0,0" Command="{Binding SelectAllVisibleCommand}"/>
          <Button Grid.Column="3" Content="Загрузить данные 1С" Style="{StaticResource WorkflowButton}"
                  Command="{Binding FetchOneCDataCommand}"/>
          <Button Grid.Column="4" Content="Найти чеки по ФП" Style="{StaticResource WorkflowButton}"
                  Margin="8,0,0,0" Command="{Binding LoadSourceOfdReportCommand}"
                  ToolTip="Использовать загруженный XLSX-отчёт ОФД / Такскома"/>
          <Button Grid.Column="6" Content="Передать готовые в работу" Style="{StaticResource BtnPrimary}"
                  MinHeight="36" Command="{Binding SendToWorkCommand}"/>
        </Grid>
      </Grid>
    </Border>

    <Grid Grid.Row="2" Margin="24,16">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="3*" MinWidth="420"/>
        <ColumnDefinition Width="8"/>
        <ColumnDefinition Width="1.05*" MinWidth="260"/>
      </Grid.ColumnDefinitions>

      <DataGrid Grid.Column="0" Style="{StaticResource CaseGrid}"
                ItemsSource="{Binding CasesView}"
                SelectedItem="{Binding SelectedCase}"
                CurrentItem="{Binding SelectedCase, Mode=TwoWay}"
                FrozenColumnCount="2">
        <DataGrid.ContextMenu>
          <ContextMenu>
            <MenuItem Header="Копировать"
                      Command="{x:Static ApplicationCommands.Copy}"
                      CommandTarget="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
          </ContextMenu>
        </DataGrid.ContextMenu>
        <DataGrid.Columns>
          <DataGridTemplateColumn Width="42" CanUserSort="False">
            <DataGridTemplateColumn.Header>
              <TextBlock Text="✓" HorizontalAlignment="Center"/>
            </DataGridTemplateColumn.Header>
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          HorizontalAlignment="Center"
                          Command="{Binding DataContext.SelectCaseCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          CommandParameter="{Binding}"
                          IsEnabled="{Binding CanEdit}"/>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <DataGridTemplateColumn Header="Состояние" Width="90">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding StateLabel}" FontWeight="SemiBold" VerticalAlignment="Center">
                  <TextBlock.Style>
                    <Style TargetType="TextBlock">
                      <Setter Property="Foreground" Value="{DynamicResource BrushText2}"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                          <Setter Property="Foreground" Value="{DynamicResource BrushGreen}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding State.CheckConfirmed}" Value="True">
                          <Setter Property="Foreground" Value="{DynamicResource BrushAccent2}"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </TextBlock.Style>
                </TextBlock>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <DataGridTextColumn Header="План" Binding="{Binding PlanStatus}" Width="125" IsReadOnly="True"/>
          <DataGridTextColumn Header="Период" Binding="{Binding PeriodLabel}" Width="100" IsReadOnly="True"/>
          <DataGridTextColumn Header="Документ" Binding="{Binding DocumentNumber}" Width="125" IsReadOnly="True"/>
          <DataGridTextColumn Header="Тип" Binding="{Binding DocumentType}" Width="130" IsReadOnly="True"/>
          <DataGridTextColumn Header="Дата" Binding="{Binding DocumentDate}" Width="145" IsReadOnly="True"/>
          <DataGridTextColumn Header="Подразделение" Binding="{Binding Department}" Width="135" IsReadOnly="True"/>
          <DataGridTextColumn Header="Номер чека" Binding="{Binding OneCCheckNumberText}" Width="110" IsReadOnly="True"/>
          <DataGridTextColumn Header="ФП чека" Binding="{Binding OneCFiscalNumberText}" Width="120" IsReadOnly="True"/>
          <DataGridTextColumn Header="Исходный чек ОФД" Binding="{Binding OriginalReceiptLookupText}" Width="145" IsReadOnly="True"/>
          <DataGridTextColumn Header="Комментарий 1С" Binding="{Binding OneCCommentText}" Width="220" IsReadOnly="True"/>
          <DataGridTextColumn Header="Пояснение ошибки" Binding="{Binding EditableProblem}" Width="260" IsReadOnly="True"/>
        </DataGrid.Columns>
      </DataGrid>

      <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch"
                    ResizeDirection="Columns" ResizeBehavior="PreviousAndNext"
                    Background="{DynamicResource BrushBorder}"/>

      <Border Grid.Column="2" Background="{DynamicResource BrushSurface1}"
              BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" CornerRadius="8">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="18">
            <Grid Margin="0,0,0,16">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBox Text="{Binding SelectedCase.DocumentNumber, Mode=OneWay}" Style="{StaticResource SelectableValue}"
                         FontSize="17"/>
                <TextBox Text="{Binding SelectedCase.DocumentType, Mode=OneWay}" Style="{StaticResource SelectableText}"
                         Foreground="{DynamicResource BrushText3}" Margin="0,3,0,0"/>
              </StackPanel>
              <TextBlock Grid.Column="1" Text="{Binding SelectedCase.StateLabel}"
                         Foreground="{DynamicResource BrushAccent2}" FontWeight="SemiBold"
                         VerticalAlignment="Top" Margin="12,2,0,0"/>
            </Grid>

            <Grid Margin="0,0,0,14">
              <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
              <StackPanel Grid.Column="0">
                <TextBlock Text="Документ" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding SelectedCase.DocumentNumber, Mode=OneWay}" Style="{StaticResource SelectableValue}"/>
              </StackPanel>
              <StackPanel Grid.Column="1">
                <TextBlock Text="Исправленная сумма" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding SelectedCase.AmountText, Mode=OneWay}" Style="{StaticResource SelectableValue}"/>
              </StackPanel>
            </Grid>

            <Border BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,1,0,1"
                    Padding="0,14" Margin="0,0,0,16">
              <StackPanel>
                <Grid Margin="0,0,0,12">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="Данные 1С" FontSize="14" FontWeight="SemiBold"/>
                  <TextBlock Grid.Column="1" Text="{Binding SelectedCase.OneCDataStatus}"
                             Foreground="{DynamicResource BrushAccent2}" FontWeight="SemiBold"/>
                </Grid>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                  </Grid.RowDefinitions>
                  <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,12">
                    <TextBlock Text="Дата документа" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding SelectedCase.OneCDocumentDateText, Mode=OneWay}" Style="{StaticResource SelectableValue}"/>
                  </StackPanel>
                  <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,12">
                    <TextBlock Text="Дата печати чека" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding SelectedCase.OneCCheckDateText, Mode=OneWay}" Style="{StaticResource SelectableValue}"/>
                  </StackPanel>
                  <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,12">
                    <TextBlock Text="Номер чека ККМ" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding SelectedCase.OneCCheckNumberText, Mode=OneWay}" Style="{StaticResource SelectableValue}"/>
                  </StackPanel>
                  <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,12">
                    <TextBlock Text="ФП чека" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding SelectedCase.OneCFiscalNumberText, Mode=OneWay}" Style="{StaticResource SelectableValue}"/>
                  </StackPanel>
                  <StackPanel Grid.Row="2" Grid.ColumnSpan="3">
                    <TextBlock Text="Комментарий 1С" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding SelectedCase.OneCCommentText, Mode=OneWay}" Style="{StaticResource SelectableText}"/>
                  </StackPanel>
                </Grid>
              </StackPanel>
            </Border>

            <TextBlock Text="Пояснение ошибки" Style="{StaticResource FieldLabel}"/>
            <TextBox Text="{Binding SelectedCase.EditableProblem, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True" TextWrapping="Wrap" MinHeight="88"
                     IsReadOnly="{Binding SelectedCase.IsCompleted}"/>
            <Button Content="Сохранить пояснение в Obsidian" Style="{StaticResource BtnSecondary}"
                    HorizontalAlignment="Left" Margin="0,8,0,18" Command="{Binding SaveProblemCommand}"/>

            <TextBlock Text="Связанные документы" Style="{StaticResource FieldLabel}"/>
            <TextBox Text="{Binding SelectedCase.RelatedDocumentsText, Mode=OneWay}" Style="{StaticResource SelectableText}"
                     Margin="0,0,0,18"/>

            <TextBlock Text="Сценарий исправления" Style="{StaticResource FieldLabel}"/>
            <ComboBox ItemsSource="{Binding ScenarioOptions}"
                      SelectedItem="{Binding SelectedCase.SelectedScenario, Mode=TwoWay}"
                      IsEnabled="{Binding SelectedCase.CanEdit}" Margin="0,0,0,4">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Converter={StaticResource ScenarioLabel}}"/>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Text="{Binding SelectedCase.ScenarioSourceLabel}"
                       Foreground="{DynamicResource BrushText3}" FontSize="11" Margin="0,0,0,18"/>

            <Border BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,0,0,1"
                    Padding="0,0,0,14" Margin="0,0,0,14">
              <StackPanel>
                <Grid Margin="0,0,0,7">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="Исходный чек ОФД" FontSize="14" FontWeight="SemiBold"/>
                  <TextBlock Grid.Column="1" Text="{Binding SelectedCase.OriginalReceiptStatus}"
                             Margin="12,0,0,0" FontWeight="SemiBold"
                             Foreground="{DynamicResource BrushAccent2}"/>
                </Grid>
                <TextBox Text="{Binding SelectedCase.OriginalReceiptDetails, Mode=OneWay}"
                         Style="{StaticResource SelectableText}"/>
              </StackPanel>
            </Border>

            <Border BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,0,0,1"
                    Padding="0,0,0,14" Margin="0,0,0,18">
              <StackPanel>
                <Grid Margin="0,0,0,7">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="План исправления" FontSize="14" FontWeight="SemiBold"/>
                  <TextBlock Grid.Column="1" Text="{Binding SelectedCase.PlanStatus}"
                             Margin="12,0,0,0" FontWeight="SemiBold"
                             Foreground="{DynamicResource BrushAccent2}"/>
                </Grid>
                <TextBox Text="{Binding SelectedCase.PlanMessage, Mode=OneWay}"
                         Style="{StaticResource SelectableText}" Margin="0,0,0,9"/>
                <TextBox Text="{Binding SelectedCase.PlanChecksText, Mode=OneWay}"
                         Style="{StaticResource SelectableValue}"/>
              </StackPanel>
            </Border>

            <TextBlock Text="Готовность к закрытию" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,9"/>
            <Grid Margin="0,0,0,5">
              <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
              <TextBlock Text="Чек в АТОЛ / ОФД"/>
              <TextBlock Grid.Column="1" Text="{Binding SelectedCase.CheckStatus}" FontWeight="SemiBold"/>
            </Grid>
            <Grid Margin="0,0,0,5">
              <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
              <TextBlock Text="Служебная записка"/>
              <TextBlock Grid.Column="1" Text="{Binding SelectedCase.MemoStatus}" FontWeight="SemiBold"/>
            </Grid>
            <Grid Margin="0,0,0,14">
              <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
              <TextBlock Text="Пояснение в 1С"/>
              <TextBlock Grid.Column="1" Text="{Binding SelectedCase.OneCStatus}" FontWeight="SemiBold"/>
            </Grid>

            <Button Content="Проверить чек по отчёту..." Style="{StaticResource BtnPrimary}"
                    Command="{Binding VerifyReportCommand}"/>
            <Button Content="Проверить служебки" Style="{StaticResource BtnSecondary}"
                    Margin="0,7,0,0" Command="{Binding VerifyMemosCommand}"/>
            <Button Content="Служебка проверена вручную" Style="{StaticResource BtnGhost}"
                    Margin="0,7,0,0" Command="{Binding MarkMemoVerifiedCommand}"/>
            <Button Content="Запись в 1С подтверждена" Style="{StaticResource BtnSecondary}"
                    Margin="0,7,0,0" Command="{Binding MarkOneCRecordedCommand}"/>
            <Button Content="Открыть служебку" Style="{StaticResource BtnGhost}"
                    Margin="0,7,0,0" Command="{Binding OpenServiceNoteCommand}"/>

            <TextBox Text="{Binding SelectedCase.LastMessage, Mode=OneWay}" Style="{StaticResource SelectableText}"
                     Foreground="{DynamicResource BrushText3}" FontSize="11" Margin="0,14,0,0"/>
          </StackPanel>
        </ScrollViewer>
      </Border>
    </Grid>

    <Border Grid.Row="3" Background="{DynamicResource BrushSurface1}"
            BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,1,0,0">
      <TextBlock Text="{Binding Status}" Margin="24,0" VerticalAlignment="Center"
                 Foreground="{DynamicResource BrushText2}" TextTrimming="CharacterEllipsis"/>
    </Border>
  </Grid>
</UserControl>
