<Window x:Class="AtolGenerator.Views.TaxcomReceiptSearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Поиск чеков в Такскоме"
        Icon="/AtolGenerator;component/Resources/app.ico"
        Width="1540" Height="920"
        MinWidth="1180" MinHeight="720"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BrushBg}"
        Loaded="OnLoaded">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*"/>
      <ColumnDefinition Width="380"/>
    </Grid.ColumnDefinitions>

    <Grid Grid.Column="0">
      <Grid.RowDefinitions>
        <RowDefinition Height="64"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>
      <Border Background="{DynamicResource BrushSurface1}"
              BorderBrush="{DynamicResource BrushBorder}"
              BorderThickness="0,0,1,1">
        <Grid Margin="20,0">
          <StackPanel VerticalAlignment="Center">
            <TextBlock Text="Поиск чеков в Такском-Кассе"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="{DynamicResource BrushText}"/>
            <TextBlock Text="Автоматическое сопоставление по ФПД"
                       FontSize="12" Margin="0,2,0,0"
                       Foreground="{DynamicResource BrushText3}"/>
          </StackPanel>
          <TextBlock x:Name="AddressText" HorizontalAlignment="Right"
                     VerticalAlignment="Center" FontSize="12"
                     Foreground="{DynamicResource BrushText3}"/>
        </Grid>
      </Border>
      <wv2:WebView2 x:Name="Browser" Grid.Row="1" DefaultBackgroundColor="White"/>
    </Grid>

    <Border Grid.Column="1" Background="{DynamicResource BrushSurface1}"
            BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1,0,0,0">
      <Grid Margin="24">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="12"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="12"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="16"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="8"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
          <Border Width="36" Height="4" CornerRadius="2" HorizontalAlignment="Left"
                  Background="{DynamicResource BrushAccent}" Margin="0,0,0,12"/>
          <TextBlock Text="Поиск исходных чеков" FontSize="22" FontWeight="SemiBold"
                     Foreground="{DynamicResource BrushText}"/>
        </StackPanel>
        <TextBlock x:Name="ProgressText" Grid.Row="1" Margin="0,7,0,0"
                   Foreground="{DynamicResource BrushText3}" FontSize="13"/>

        <Border Grid.Row="3" Background="{DynamicResource BrushSurface2}"
                BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                CornerRadius="6" Padding="16">
          <StackPanel>
            <TextBlock Text="ТЕКУЩИЙ ЗАПРОС" Foreground="{DynamicResource BrushText3}"
                       FontSize="11" FontWeight="SemiBold"/>
            <TextBlock x:Name="CurrentDocumentText" Margin="0,7,0,0" FontSize="14"
                       Foreground="{DynamicResource BrushText2}" FontWeight="SemiBold"
                       TextWrapping="Wrap"/>
            <TextBlock x:Name="CurrentFiscalSignText" Margin="0,4,0,0"
                       Foreground="{DynamicResource BrushAccent}" FontSize="16" FontWeight="SemiBold"/>
            <TextBlock x:Name="CurrentPeriodText" Margin="0,4,0,0"
                       Foreground="{DynamicResource BrushText3}" FontSize="11"/>
          </StackPanel>
        </Border>

        <ListBox x:Name="ResultList" Grid.Row="5"
                 Background="Transparent" BorderThickness="0"
                 Foreground="{DynamicResource BrushText2}"
                 FontSize="13" Padding="0,4"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>

        <TextBlock x:Name="StatusText" Grid.Row="7" TextWrapping="Wrap"
                   Foreground="{DynamicResource BrushText2}" FontSize="13"/>

        <Grid Grid.Row="9">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="8"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <Button x:Name="SearchButton" Content="Продолжить поиск"
                  Style="{StaticResource BtnPrimary}" Padding="18,9"
                  Click="SearchButton_Click"/>
          <Button Grid.Column="2" Content="Закрыть"
                  Style="{StaticResource BtnSecondary}" Padding="18,9"
                  Click="CloseButton_Click"/>
        </Grid>
      </Grid>
    </Border>
  </Grid>
</Window>
