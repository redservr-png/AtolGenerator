<Window x:Class="AtolGenerator.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AtolGenerator.ViewModels"
        xmlns:cv="clr-namespace:AtolGenerator.Views.Converters"
        xmlns:views="clr-namespace:AtolGenerator.Views"
        Title="АТОЛ Чек-генератор"
        Icon="/Resources/app.ico"
        Height="940" Width="1560"
        MinHeight="760" MinWidth="1240"
        Background="{DynamicResource BrushBg}"
        WindowStartupLocation="CenterScreen"
        Loaded="OnLoaded">

  <Window.DataContext>
    <vm:MainViewModel/>
  </Window.DataContext>

  <Window.Resources>
    <cv:BoolToVisibilityConverter        x:Key="BoolVis"/>
    <cv:InverseBoolToVisibilityConverter x:Key="InvBoolVis"/>
    <cv:ZeroToVisibilityConverter        x:Key="ZeroVis"/>
    <cv:NonZeroToBoolConverter           x:Key="NonZeroBool"/>
    <cv:StringEqualConverter             x:Key="StrEq"/>
    <cv:InverseBoolConverter             x:Key="InvBool"/>
    <cv:OrderKindLabelConverter             x:Key="KindLabel"/>
    <cv:CorrectionScenarioLabelConverter    x:Key="ScenarioLabel"/>
    <cv:OrderKindToBrushConverter           x:Key="KindBrush"/>
    <cv:OrderKindToVisibilityConverter      x:Key="KindVis"/>
    <cv:SourceDocumentTypeLabelConverter    x:Key="DocTypeLabel"/>
    <cv:SourceDocumentTypeVisibilityConverter x:Key="DocTypeVis"/>
    <cv:UnknownScenarioVisibilityConverter  x:Key="UnknownVis"/>

    <!-- Стиль текста в ячейках DataGrid -->
    <Style x:Key="DataGridTextStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource BrushText2}"/>
      <Setter Property="FontSize"   Value="12"/>
      <Setter Property="Padding"    Value="0,0,4,0"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="72"/>   <!-- header -->
      <RowDefinition Height="*"/>    <!-- content -->
      <RowDefinition Height="32"/>   <!-- status bar -->
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="244"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <!-- ══════════ SIDEBAR ══════════ -->
    <Border Grid.Row="0" Grid.RowSpan="3" Grid.Column="0"
            Background="{DynamicResource BrushSidebarBg}"
            BorderBrush="{DynamicResource BrushSidebarBorder}"
            BorderThickness="0,0,1,0">
      <Grid Margin="18,20">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,30">
          <Border Width="42" Height="42" CornerRadius="6" Margin="0,0,12,0">
            <Border.Background>
              <SolidColorBrush Color="#0F766E"/>
            </Border.Background>
            <TextBlock Text="&#xE8B7;" FontFamily="Segoe Fluent Icons"
                       FontSize="19" Foreground="White"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <StackPanel VerticalAlignment="Center">
            <TextBlock Text="АТОЛ" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource BrushSidebarMuted}"/>
            <TextBlock Text="Чек-генератор" FontSize="15" FontWeight="Bold"
                       Foreground="{DynamicResource BrushSidebarText}" Margin="0,2,0,0"/>
          </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="1">
          <TextBlock Text="ОПЕРАЦИИ" FontSize="11" FontWeight="SemiBold"
                     Foreground="{DynamicResource BrushSidebarMuted}" Margin="0,0,0,10"/>
          <Button Style="{StaticResource SidebarButton}"
                  HorizontalContentAlignment="Left"
                  Margin="0,0,0,8"
                  Command="{Binding OpenWorkspaceCommand}"
                  CommandParameter="refunds">
            <TextBlock Text="↩   Возвраты по заказам"/>
          </Button>
          <Button Style="{StaticResource SidebarButton}"
                  HorizontalContentAlignment="Left"
                  Margin="0,0,0,8"
                  Command="{Binding OpenWorkspaceCommand}"
                  CommandParameter="realizationCorrections">
            <TextBlock Text="⇄   Коррекции реализаций 1С"/>
          </Button>
          <Button Style="{StaticResource SidebarButton}"
                  HorizontalContentAlignment="Left"
                  Margin="0,0,0,8"
                  Command="{Binding OpenWorkspaceCommand}"
                  CommandParameter="obsidian">
            <TextBlock Text="▧   Исправление чеков"/>
          </Button>
          <Button Style="{StaticResource SidebarButton}"
                  HorizontalContentAlignment="Left"
                  Margin="0,0,0,8"
                  Command="{Binding OpenWorkspaceCommand}"
                  CommandParameter="correctionWork">
            <TextBlock Text="▦   Пробитие исправлений"/>
          </Button>
          <Button Style="{StaticResource SidebarButton}"
                  HorizontalContentAlignment="Left"
                  Margin="0,0,0,22"
                  Command="{Binding OpenWorkspaceCommand}"
                  CommandParameter="reports">
            <TextBlock Text="▤   Отчёты"/>
          </Button>

          <TextBlock Text="СЕРВИС" FontSize="11" FontWeight="SemiBold"
                     Foreground="{DynamicResource BrushSidebarMuted}" Margin="0,0,0,10"/>
          <Button Style="{StaticResource SidebarButton}"
                  HorizontalContentAlignment="Left"
                  Margin="0,0,0,8"
                  Command="{Binding OpenWorkspaceCommand}"
                  CommandParameter="payment">
            <TextBlock Text="＋   Оплаты / приход"/>
          </Button>
          <Button Style="{StaticResource SidebarButton}"
                  HorizontalContentAlignment="Left"
                  Margin="0,0,0,22"
                  Command="{Binding OpenSettingsCommand}">
            <TextBlock Text="⚙   Настройки"/>
          </Button>
        </StackPanel>

        <StackPanel Grid.Row="3">
          <Separator Background="{DynamicResource BrushSidebarSeparator}" Margin="0,0,0,14"/>
          <TextBlock Text="Кассир" FontSize="11" Foreground="{DynamicResource BrushSidebarMuted}"/>
          <TextBlock FontSize="13" FontWeight="SemiBold"
                     Foreground="{DynamicResource BrushSidebarText}" Margin="0,3,0,14">
            <Run Text="Кассир: "/>
            <Run Text="{Binding SelectedCashierShort, Mode=OneWay}"/>
          </TextBlock>
          <TextBlock Text="Готово к работе" FontSize="12"
                     Foreground="{DynamicResource BrushSidebarStatus}"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ══════════ HEADER ══════════ -->
    <Border Grid.Row="0" Grid.Column="1"
            Background="{DynamicResource BrushSurface1}"
            BorderBrush="{DynamicResource BrushBorder}"
            BorderThickness="0,0,0,1">
      <Grid Margin="24,0">
        <StackPanel VerticalAlignment="Center">
          <TextBlock Text="Рабочее место кассира" FontSize="16" FontWeight="SemiBold"/>
          <TextBlock Text="Чеки, исправления и сверка фискальных данных"
                     FontSize="12" Foreground="{DynamicResource BrushText3}" Margin="0,3,0,0"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
          <Border Background="{DynamicResource BrushSurface2}"
                  BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                  CornerRadius="6" Padding="11,7" Margin="0,0,10,0">
            <StackPanel Orientation="Horizontal">
              <Ellipse Width="7" Height="7" Fill="{DynamicResource BrushGreen}" Margin="0,0,8,0"/>
              <TextBlock Text="ИП Шевелев Е.Н. · ФФД 1.05" FontSize="12"
                         Foreground="{DynamicResource BrushText2}"/>
            </StackPanel>
          </Border>
          <Button Content="Исправления" Style="{StaticResource BtnSecondary}"
                  Padding="12,7" FontSize="12" Margin="0,0,8,0"
                  ToolTip="Подготовить исправительные XML"
                  Command="{Binding OpenWorkspaceCommand}" CommandParameter="correctionWork"/>
          <Button Content="Настройки" Style="{StaticResource BtnSecondary}"
                  Padding="12,7" FontSize="12" Command="{Binding OpenSettingsCommand}"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ══════════ CONTENT ══════════ -->
    <ScrollViewer Grid.Row="1" Grid.Column="1"
                  VerticalScrollBarVisibility="Auto"
                  Visibility="{Binding ShowMainWorkspace, Converter={StaticResource BoolVis}}">
      <Grid Margin="28,24,28,24">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>  <!-- Row 0: основной контент -->
          <RowDefinition Height="Auto"/>  <!-- Row 1: результаты + предпросмотр -->
          <RowDefinition Height="Auto"/>  <!-- Row 2: 1С реализации -->
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="20"/>
          <ColumnDefinition Width="430"/>
        </Grid.ColumnDefinitions>

        <!-- ════ LEFT COLUMN ════ -->
        <StackPanel Grid.Row="0" Grid.Column="0">

          <Grid Margin="0,0,0,18">
            <StackPanel>
              <TextBlock Text="Формирование чеков" Style="{StaticResource PageTitle}"/>
              <TextBlock Text="Подготовка возвратов, оплат и документов по данным 1С"
                         Style="{StaticResource PageSubtitle}" Margin="0,4,0,0"/>
            </StackPanel>
            <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                    Background="{DynamicResource BrushSurface3}" CornerRadius="6" Padding="10,6">
              <TextBlock Text="ФФД 1.05" FontSize="12" FontWeight="SemiBold"
                         Foreground="{DynamicResource BrushAccent2}"/>
            </Border>
          </Grid>

          <!-- Tabs -->
          <Border Background="{DynamicResource BrushSurface2}"
                  CornerRadius="10" Padding="4"
                  Visibility="Collapsed">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
              </Grid.ColumnDefinitions>
              <ToggleButton Grid.Column="0" Style="{StaticResource TabBtn}"
                            Content="💳  Оплаты"
                            IsChecked="{Binding Tab, Converter={StaticResource StrEq}, ConverterParameter=payment, Mode=TwoWay}"
                            Command="{Binding SwitchTabCommand}" CommandParameter="payment"/>
              <ToggleButton Grid.Column="1" Style="{StaticResource TabBtn}"
                            Content="📦  Реализации / Возвраты"
                            IsChecked="{Binding Tab, Converter={StaticResource StrEq}, ConverterParameter=realization, Mode=TwoWay}"
                            Command="{Binding SwitchTabCommand}" CommandParameter="realization"/>
            </Grid>
          </Border>

          <!-- Check Type card -->
          <Border Style="{StaticResource Card}" Margin="0,0,0,14">
            <StackPanel>
              <!-- Section title -->
              <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                <Border Width="3" Height="13" Background="{DynamicResource BrushAccent}"
                        CornerRadius="2" Margin="0,0,7,0"/>
                <TextBlock Text="Тип чека" Style="{StaticResource SectionTitle}" Margin="0"/>
              </StackPanel>

              <!-- Radio chips -->
              <WrapPanel>
                <RadioButton Style="{StaticResource RadioChip}" Content="Приход"
                             IsChecked="{Binding CheckType, Converter={StaticResource StrEq}, ConverterParameter=sell, Mode=TwoWay}"/>
                <RadioButton Style="{StaticResource RadioChip}" Content="Возврат прихода"
                             IsChecked="{Binding CheckType, Converter={StaticResource StrEq}, ConverterParameter=sell_refund, Mode=TwoWay}"/>
                <RadioButton Style="{StaticResource RadioChip}" Content="Коррекция прихода"
                             IsChecked="{Binding CheckType, Converter={StaticResource StrEq}, ConverterParameter=sell_correction, Mode=TwoWay}"
                             ToolTip="Коррекция не поддерживается через АТОЛ API — пробейте вручную через XML"/>
                <RadioButton Style="{StaticResource RadioChip}" Content="Коррекция расхода"
                             IsChecked="{Binding CheckType, Converter={StaticResource StrEq}, ConverterParameter=buy_correction, Mode=TwoWay}"
                             ToolTip="Коррекция не поддерживается через АТОЛ API — пробейте вручную через XML"/>
                <RadioButton Style="{StaticResource RadioChip}" Content="Коррекция возврата"
                             IsChecked="{Binding CheckType, Converter={StaticResource StrEq}, ConverterParameter=buy_refund, Mode=TwoWay}"
                             Visibility="{Binding ShowBuyRefundOption, Converter={StaticResource BoolVis}}"/>
              </WrapPanel>

              <!-- Payment Type (только на вкладке оплаты; реализация всегда тип 14 — аванс) -->
              <StackPanel Margin="0,14,0,0"
                          Visibility="{Binding ShowPaymentType, Converter={StaticResource BoolVis}}">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                  <Border Width="3" Height="13" Background="{DynamicResource BrushAccent}"
                          CornerRadius="2" Margin="0,0,7,0"/>
                  <TextBlock Text="Способ оплаты" Style="{StaticResource SectionTitle}" Margin="0"/>
                </StackPanel>
                <WrapPanel>
                  <RadioButton Style="{StaticResource RadioChip}" Content="Наличные"
                               IsChecked="{Binding PaymentType, Converter={StaticResource StrEq}, ConverterParameter=cash, Mode=TwoWay}"/>
                  <RadioButton Style="{StaticResource RadioChip}" Content="Безналичные"
                               IsChecked="{Binding PaymentType, Converter={StaticResource StrEq}, ConverterParameter=card, Mode=TwoWay}"/>
                </WrapPanel>
              </StackPanel>

              <!-- Correction box -->
              <Border Visibility="{Binding ShowCorrectionBox, Converter={StaticResource BoolVis}}"
                      Background="#12F0960F" BorderBrush="#33F0960F"
                      BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,10,0,0">
                <StackPanel>
                  <TextBlock Text="Данные коррекции" FontSize="12" FontWeight="SemiBold"
                             Foreground="{DynamicResource BrushOrange}"
                             Margin="0,0,0,10"/>
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition/>
                      <ColumnDefinition Width="14"/>
                      <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="Дата события *" Style="{StaticResource FieldLabel}"/>
                      <TextBox Text="{Binding CorrectionDate, UpdateSourceTrigger=PropertyChanged}"
                               Tag="ДД.ММ.ГГГГ"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                      <TextBlock Text="Номер документа основания" Style="{StaticResource FieldLabel}"/>
                      <TextBox Text="{Binding CorrectionNumber, UpdateSourceTrigger=PropertyChanged}"
                               Tag="авто: Основание_[номер заказа]"/>
                      <TextBlock Text="Оставьте пустым — заполнится автоматически"
                                 Style="{StaticResource HintText}"/>
                    </StackPanel>
                  </Grid>
                </StackPanel>
              </Border>

            </StackPanel>
          </Border>

          <!-- Bulk input card -->
          <Border Style="{StaticResource Card}" Margin="0,0,0,14">
            <StackPanel>
              <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                <Border Width="3" Height="13" Background="{DynamicResource BrushAccent}"
                        CornerRadius="2" Margin="0,0,7,0"/>
                <TextBlock Text="Массовый ввод заказов" Style="{StaticResource SectionTitle}" Margin="0"/>
              </StackPanel>
              <TextBlock Text="Вставьте сообщение с заказами" Style="{StaticResource FieldLabel}"/>
              <TextBox Text="{Binding BulkText, UpdateSourceTrigger=PropertyChanged}"
                       AcceptsReturn="True" MinHeight="112" TextWrapping="Wrap"
                       VerticalScrollBarVisibility="Auto"
                       Tag="Заказ покупателя т0000027760 от 23.03.2026 12:37:39 сумма 3000 Шкрабий Екатерина Васильевна"/>
              <TextBlock Text="Ctrl+V · Разделитель: «;» или перевод строки."
                         Style="{StaticResource HintText}"/>
              <WrapPanel Margin="0,10,0,0">
                <Button Content="Распознать заказы"
                        Style="{StaticResource BtnPrimary}"
                        Padding="13,7" FontSize="13"
                        Margin="0,0,8,0"
                        Command="{Binding ParseBulkCommand}"/>
                <Button Content="Импорт из Excel"
                        Style="{StaticResource BtnSecondary}"
                        Padding="13,7" FontSize="13"
                        Visibility="{Binding IsRealizationTab, Converter={StaticResource BoolVis}}"
                        Command="{Binding ImportExcelCommand}"/>
                <Button Content="Загрузить из 1С"
                        Style="{StaticResource BtnSecondary}"
                        Padding="13,7" FontSize="13" Margin="8,0,0,0"
                        Visibility="{Binding IsRealizationTab, Converter={StaticResource BoolVis}}"
                        Command="{Binding ToggleOneCPanelCommand}"/>
              </WrapPanel>

              <!-- 1C settings panel -->
              <Border Visibility="{Binding OneCPanelVisible, Converter={StaticResource BoolVis}}"
                      Background="{DynamicResource BrushSurface2}"
                      BorderBrush="{DynamicResource BrushBorder}"
                      BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,10,0,0">
                <StackPanel>
                  <TextBlock Text="ПОДКЛЮЧЕНИЕ К 1С" FontSize="11" FontWeight="Bold"
                             Foreground="{DynamicResource BrushAccent2}" Margin="0,0,0,10"/>

                  <!-- V83 not found warning -->
                  <Border Background="#1AFF6B00" BorderBrush="#44FF6B00"
                          BorderThickness="1" CornerRadius="6" Padding="10,7" Margin="0,0,0,10"
                          Visibility="{Binding IsOneCAvailable, Converter={StaticResource InvBoolVis}}">
                    <TextBlock Text="⚠️ Компонент V83.COMConnector не найден. Установите клиент 1С на этот компьютер."
                               FontSize="12" Foreground="{DynamicResource BrushOrange}" TextWrapping="Wrap"/>
                  </Border>

                  <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="Сервер 1С" Style="{StaticResource FieldLabel}"/>
                      <TextBox Text="{Binding OneCServer, UpdateSourceTrigger=PropertyChanged}"
                               Tag="server1c"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                      <TextBlock Text="Имя базы (Ref)" Style="{StaticResource FieldLabel}"/>
                      <TextBox Text="{Binding OneCDatabase, UpdateSourceTrigger=PropertyChanged}"
                               Tag="ut_new"/>
                    </StackPanel>
                  </Grid>
                  <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="Пользователь" Style="{StaticResource FieldLabel}"/>
                      <TextBox Text="{Binding OneCUser, UpdateSourceTrigger=PropertyChanged}"
                               Tag="Администратор"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                      <TextBlock Text="Пароль" Style="{StaticResource FieldLabel}"/>
                      <PasswordBox Tag="••••••"
                                   cv:PasswordHelper.Attach="True"
                                   cv:PasswordHelper.Password="{Binding OneCPassword, Mode=TwoWay}"/>
                    </StackPanel>
                  </Grid>
                  <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="Дата от" Style="{StaticResource FieldLabel}"/>
                      <TextBox Text="{Binding OneCFromDate, UpdateSourceTrigger=PropertyChanged}"
                               Tag="дд.мм.гггг"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                      <TextBlock Text="Дата до" Style="{StaticResource FieldLabel}"/>
                      <TextBox Text="{Binding OneCToDate, UpdateSourceTrigger=PropertyChanged}"
                               Tag="дд.мм.гггг"/>
                    </StackPanel>
                  </Grid>

                  <WrapPanel>
                    <Button Content="🔌  Проверить подключение"
                            Style="{StaticResource BtnSecondary}"
                            Padding="11,6" FontSize="12"
                            Command="{Binding TestOneCCommand}"/>
                    <Button Content="⬇  Загрузить реализации"
                            Style="{StaticResource BtnPrimary}"
                            Padding="11,6" FontSize="12" Margin="8,0,0,0"
                            Command="{Binding LoadFromOneCCommand}"/>
                  </WrapPanel>
                  <TextBlock Text="{Binding OneCStatus}"
                             FontSize="12" Foreground="{DynamicResource BrushText2}"
                             Margin="0,8,0,0" TextWrapping="Wrap"/>
                </StackPanel>
              </Border>

            </StackPanel>
          </Border>

          <!-- Divider -->
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Separator Grid.Column="0" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" Text="или введите один заказ вручную"
                       Foreground="{DynamicResource BrushText3}" FontSize="12"
                       Margin="10,0"/>
            <Separator Grid.Column="2" VerticalAlignment="Center"/>
          </Grid>

          <!-- Single order card -->
          <Border Style="{StaticResource Card}" Margin="0,0,0,14">
            <StackPanel>
              <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                <Border Width="3" Height="13" Background="{DynamicResource BrushAccent}"
                        CornerRadius="2" Margin="0,0,7,0"/>
                <TextBlock Text="ДАННЫЕ ОДНОГО ЧЕКА" Style="{StaticResource SectionTitle}" Margin="0"/>
              </StackPanel>

              <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                  <TextBlock Text="Номер заказа *" Style="{StaticResource FieldLabel}"/>
                  <TextBox Text="{Binding SingleOrderNum, UpdateSourceTrigger=PropertyChanged}"
                           Tag="т0000027760"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                  <TextBlock Text="Дата заказа" Style="{StaticResource FieldLabel}"/>
                  <TextBox Text="{Binding SingleOrderDate, UpdateSourceTrigger=PropertyChanged}"
                           Tag="23.03.2026 12:37:39"/>
                </StackPanel>
              </Grid>

              <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                  <TextBlock Text="Сумма, руб. *" Style="{StaticResource FieldLabel}"/>
                  <TextBox Text="{Binding SingleAmount, UpdateSourceTrigger=PropertyChanged}"
                           Tag="3000"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                  <TextBlock Text="ФИО покупателя" Style="{StaticResource FieldLabel}"/>
                  <TextBox Text="{Binding SingleCustomer, UpdateSourceTrigger=PropertyChanged}"
                           Tag="Иванов Иван Иванович"/>
                </StackPanel>
              </Grid>

              <!-- Service / agent checkbox -->
              <CheckBox Content="🔧  Услуга (поставщик / агент)"
                        IsChecked="{Binding IsServiceProvider}"
                        Margin="0,4,0,0"/>

              <!-- Agent panel -->
              <Border Visibility="{Binding ShowAgentPanel, Converter={StaticResource BoolVis}}"
                      Background="{DynamicResource BrushSurface2}"
                      BorderBrush="{DynamicResource BrushBorder}"
                      BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,10,0,0">
                <StackPanel>
                  <TextBlock Text="ПОСТАВЩИК УСЛУГИ" FontSize="11" FontWeight="Bold"
                             Foreground="{DynamicResource BrushAccent2}"
                             Margin="0,0,0,10"/>
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="Тип услуги" Style="{StaticResource FieldLabel}"/>
                      <ComboBox ItemsSource="{x:Static cv:ServiceTypeList.Items}"
                                SelectedItem="{Binding SelectedServiceType}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                      <TextBlock Text="Город" Style="{StaticResource FieldLabel}"/>
                      <ComboBox ItemsSource="{Binding AvailableCities}"
                                SelectedItem="{Binding SelectedCity}"/>
                    </StackPanel>
                  </Grid>
                  <TextBlock Text="{Binding AgentInfoText}"
                             FontSize="12" Foreground="{DynamicResource BrushText2}"
                             Margin="0,8,0,0" LineHeight="22"
                             TextWrapping="Wrap"/>
                </StackPanel>
              </Border>

              <!-- Items section (realization) -->
              <StackPanel Visibility="{Binding ShowItemsSection, Converter={StaticResource BoolVis}}"
                          Margin="0,10,0,0">
                <Separator/>
                <TextBlock Text="ТОВАРНЫЕ ПОЗИЦИИ" FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource BrushText3}" Margin="0,0,0,8"/>
                <ItemsControl ItemsSource="{Binding CurrentItems}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Grid Margin="0,0,0,7">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition/>
                          <ColumnDefinition Width="12"/>
                          <ColumnDefinition Width="80"/>
                          <ColumnDefinition Width="12"/>
                          <ColumnDefinition Width="110"/>
                          <ColumnDefinition Width="12"/>
                          <ColumnDefinition Width="34"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                 Tag="Наименование"/>
                        <TextBox Grid.Column="2" Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"
                                 Tag="Кол-во"/>
                        <TextBox Grid.Column="4" Text="{Binding Sum, UpdateSourceTrigger=PropertyChanged}"
                                 Tag="Сумма, руб."/>
                        <Button  Grid.Column="6" Content="✕"
                                 Style="{StaticResource BtnDelete}"
                                 Command="{Binding DataContext.DeleteItemCommand,
                                           RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                 CommandParameter="{Binding}"/>
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Button Content="＋  Добавить позицию"
                        Style="{StaticResource BtnGhost}"
                        Margin="0,4,0,0"
                        Command="{Binding AddItemCommand}"/>
              </StackPanel>

              <Separator Margin="0,14"/>
              <Button Content="＋  Добавить в список"
                      Style="{StaticResource BtnSecondary}"
                      HorizontalAlignment="Left"
                      Command="{Binding AddSingleCommand}"/>
            </StackPanel>
          </Border>

        </StackPanel>

        <!-- ════ RIGHT COLUMN ════ -->
        <StackPanel Grid.Row="0" Grid.Column="2">

          <!-- АТОЛ Online panel -->
          <Border Background="{DynamicResource BrushSurface1}"
                  BorderBrush="{DynamicResource BrushBorder}"
                  BorderThickness="1" CornerRadius="10" Padding="16"
                  Margin="0,0,0,14"
                  Visibility="{Binding ShowAtolPanel, Converter={StaticResource BoolVis}}">
            <StackPanel>
              <TextBlock Text="🔑  АТОЛ ONLINE — НАСТРОЙКИ API"
                         FontSize="11" FontWeight="Bold"
                         Foreground="{DynamicResource BrushAccent2}" Margin="0,0,0,10"/>
              <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                  <TextBlock Text="Логин API" Style="{StaticResource FieldLabel}"/>
                  <TextBox Text="{Binding AtolLogin, UpdateSourceTrigger=PropertyChanged}"
                           Tag="ts-alleya-ru"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                  <TextBlock Text="Пароль API" Style="{StaticResource FieldLabel}"/>
                  <PasswordBox Tag="••••••"
                               cv:PasswordHelper.Attach="True"
                               cv:PasswordHelper.Password="{Binding AtolPassword, Mode=TwoWay}"/>
                </StackPanel>
              </Grid>
              <StackPanel Margin="0,0,0,10">
                <TextBlock Text="Group Code" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding AtolGroupCode, UpdateSourceTrigger=PropertyChanged}"
                         Tag="ts-alleya-ru_11415"/>
              </StackPanel>
              <WrapPanel>
                <Button Content="💾  Сохранить"
                        Style="{StaticResource BtnSecondary}"
                        Padding="11,6" FontSize="12" Margin="0,0,8,0"
                        Command="{Binding SaveAtolSettingsCommand}"/>
                <Button Content="🔌  Проверить подключение"
                        Style="{StaticResource BtnSecondary}"
                        Padding="11,6" FontSize="12"
                        Command="{Binding TestAtolConnectionCommand}"/>
              </WrapPanel>
              <TextBlock Text="{Binding AtolStatus}"
                         FontSize="12" Foreground="{DynamicResource BrushText2}"
                         Margin="0,8,0,0" TextWrapping="Wrap"/>
              <!-- Блок ошибок (показывается когда есть ошибки) -->
              <Border Background="#1AFF4444" BorderBrush="#44FF4444"
                      BorderThickness="1" CornerRadius="6" Padding="10,8"
                      Margin="0,8,0,0"
                      Visibility="{Binding HasAtolError, Converter={StaticResource BoolVis}}">
                <StackPanel>
                  <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="❌  Ошибки пробития:"
                               FontSize="11" FontWeight="Bold"
                               Foreground="{DynamicResource BrushRed}"/>
                    <TextBlock Text="{Binding AtolLogPath, StringFormat='  (лог: {0})'}"
                               FontSize="10" Foreground="{DynamicResource BrushText3}"
                               VerticalAlignment="Center"/>
                  </StackPanel>
                  <ScrollViewer MaxHeight="100" VerticalScrollBarVisibility="Auto"
                                HorizontalScrollBarVisibility="Disabled">
                    <TextBlock Text="{Binding AtolLastError}"
                               FontSize="11" Foreground="{DynamicResource BrushRed}"
                               TextWrapping="Wrap" FontFamily="Consolas"/>
                  </ScrollViewer>
                </StackPanel>
              </Border>
            </StackPanel>
          </Border>

          <!-- Orders list card -->
          <Border Style="{StaticResource Card}" Margin="0,0,0,14">
            <StackPanel>
              <Grid Margin="0,0,0,10">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                  <Border Width="3" Height="13" Background="{DynamicResource BrushAccent}"
                          CornerRadius="2" Margin="0,0,7,0"/>
                  <TextBlock Text="ДОКУМЕНТЫ К ПРОБИТИЮ" Style="{StaticResource SectionTitle}" Margin="0"/>
                  <TextBlock Text="{Binding OrderCount, StringFormat=' ({0})'}"
                             FontSize="12" Foreground="{DynamicResource BrushText3}"
                             VerticalAlignment="Center"/>
                </StackPanel>
                <Button Content="🗑 Очистить"
                        Style="{StaticResource BtnGhost}"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        Padding="8,4" FontSize="11"
                        Command="{Binding ClearOrdersCommand}"
                        IsEnabled="{Binding OrderCount, Converter={StaticResource NonZeroBool}}"/>
              </Grid>

              <!-- Empty placeholder -->
              <TextBlock Text="Заказы не добавлены"
                         Foreground="{DynamicResource BrushText3}" FontSize="13"
                         HorizontalAlignment="Center" Padding="0,14"
                         Visibility="{Binding OrderCount, Mode=OneWay, Converter={StaticResource ZeroVis}}"/>

              <!-- Orders list -->
              <ItemsControl ItemsSource="{Binding Orders}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Background="{DynamicResource BrushSurface2}"
                            BorderBrush="{DynamicResource BrushBorder}"
                            BorderThickness="1" CornerRadius="8"
                            Padding="0,8,10,8" Margin="0,0,0,6"
                            ToolTip="{Binding Notes}">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="Auto"/>
                          <ColumnDefinition Width="10"/>
                          <ColumnDefinition/>
                          <ColumnDefinition Width="Auto"/>
                          <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <!-- Цветная полоса слева (только для коррекций) -->
                        <Border Grid.Column="0" Width="4"
                                Background="{Binding Kind, Converter={StaticResource KindBrush}}"
                                CornerRadius="2,0,0,2"/>
                        <StackPanel Grid.Column="2">
                          <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding OrderNum}"
                                       FontFamily="Courier New" FontSize="12"
                                       Foreground="{DynamicResource BrushAccent2}"/>
                            <!-- Чип с типом документа из 1С (Реализация/Опл.картой/ПКО/...) -->
                            <Border Background="#332288CC" BorderBrush="#882288CC"
                                    BorderThickness="1" CornerRadius="3"
                                    Padding="5,1" Margin="8,0,0,0"
                                    Visibility="{Binding DocumentType, Converter={StaticResource DocTypeVis}}">
                              <TextBlock Text="{Binding DocumentType, Converter={StaticResource DocTypeLabel}}"
                                         FontSize="10" Foreground="#88CCEE"/>
                            </Border>
                            <!-- Чип с типом коррекции (видим только для коррекций) -->
                            <Border Background="#33FF8800" BorderBrush="#88FF8800"
                                    BorderThickness="1" CornerRadius="3"
                                    Padding="5,1" Margin="6,0,0,0"
                                    Visibility="{Binding Kind, Converter={StaticResource KindVis}}">
                              <TextBlock Text="{Binding Kind, Converter={StaticResource KindLabel}}"
                                         FontSize="10" Foreground="#FFCC88"/>
                            </Border>
                          </StackPanel>
                          <TextBlock Text="{Binding OrderDate}"
                                     FontSize="11" Foreground="{DynamicResource BrushText3}"
                                     Margin="0,1,0,0"/>
                          <!-- Сценарий коррекции (видим только для коррекций) -->
                          <TextBlock FontSize="10" Foreground="#FFAA66"
                                     Margin="0,2,0,0" FontStyle="Italic"
                                     Text="{Binding CorrectionScenario, Converter={StaticResource ScenarioLabel}, StringFormat='→ {0}'}"
                                     Visibility="{Binding Kind, Converter={StaticResource KindVis}}"/>
                          <!-- Предупреждение для Unknown сценариев -->
                          <TextBlock Text="⚠ Сценарий не определён — XML не сформируется. Выберите тип коррекции вручную."
                                     FontSize="10" Foreground="#FF6644" FontWeight="SemiBold"
                                     Margin="0,2,0,0" TextWrapping="Wrap"
                                     Visibility="{Binding CorrectionScenario, Converter={StaticResource UnknownVis}}"/>
                        </StackPanel>
                        <TextBlock Grid.Column="3"
                                   FontWeight="Bold" FontSize="14"
                                   Foreground="{DynamicResource BrushGreen}"
                                   VerticalAlignment="Center" Margin="8,0">
                          <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0:N0} ₽">
                              <Binding Path="Amount"/>
                            </MultiBinding>
                          </TextBlock.Text>
                        </TextBlock>
                        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                          <!-- Кнопка ✏ редактирования (видна только для коррекций) -->
                          <Button Content="✏"
                                  Style="{StaticResource BtnDelete}"
                                  FontSize="14" Margin="0,0,4,0"
                                  ToolTip="Изменить тип коррекции, суммы, ФП и т.д."
                                  Visibility="{Binding Kind, Converter={StaticResource KindVis}}"
                                  Command="{Binding DataContext.EditOrderCommand,
                                            RelativeSource={RelativeSource AncestorType=Window}}"
                                  CommandParameter="{Binding}"/>
                          <Button Content="✕"
                                  Style="{StaticResource BtnDelete}"
                                  Command="{Binding DataContext.DeleteOrderCommand,
                                            RelativeSource={RelativeSource AncestorType=Window}}"
                                  CommandParameter="{Binding}"/>
                        </StackPanel>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <!-- Generate box -->
          <Border Style="{StaticResource Panel}">
            <StackPanel>
              <TextBlock FontSize="13" Foreground="{DynamicResource BrushText2}"
                         Margin="0,0,0,12" LineHeight="22">
                <Run Text="Будет создано: "/>
                <Run Text="{Binding OrderCount, Mode=OneWay}" FontWeight="Bold"
                     Foreground="{DynamicResource BrushText}"/>
                <Run Text=" чек(ов) + "/>
                <Run Text="{Binding OrderCount, Mode=OneWay}" FontWeight="Bold"
                     Foreground="{DynamicResource BrushText}"/>
                <Run Text=" служебных записок"/>
              </TextBlock>
              <!-- Выбор кассира -->
              <TextBlock Text="Кассир" FontSize="11"
                         Foreground="{DynamicResource BrushText3}" Margin="0,0,0,4"/>
              <ComboBox ItemsSource="{Binding AvailableCashiers}"
                        SelectedItem="{Binding SelectedCashier, Mode=TwoWay}"
                        Margin="0,0,0,12" Padding="10,7" FontSize="12">
                <ComboBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding Display}" FontSize="12"/>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>

              <CheckBox Content="Объединить все чеки в 1 XML-файл"
                        IsChecked="{Binding MergeXml}"
                        Margin="0,0,0,10" FontSize="13"/>
              <Button Style="{StaticResource BtnGenerate}"
                      Command="{Binding GenerateCommand}"
                      Content="Сформировать документы"
                      IsEnabled="{Binding OrderCount, Mode=OneWay, Converter={StaticResource NonZeroBool}}"/>
              <Button Style="{StaticResource BtnPrimary}"
                      Command="{Binding PunchOrdersViaAtolCommand}"
                      IsEnabled="{Binding CanPunchOrdersViaAtol, Mode=OneWay}"
                      ToolTip="{Binding CorrectionPunchHint}"
                      ToolTipService.ShowOnDisabled="True"
                      Margin="0,8,0,0" Padding="0,11"
                      Content="Пробить в АТОЛ Online"/>
              <!-- Подсказка при выборе коррекции или наличии XML-only коррекций в списке -->
              <TextBlock Text="{Binding CorrectionPunchHint}"
                         FontSize="11" Foreground="#FFAA44"
                         HorizontalAlignment="Center" Margin="0,4,0,0"
                         TextWrapping="Wrap" TextAlignment="Center"
                         Visibility="{Binding ShowCorrectionPunchHint, Converter={StaticResource BoolVis}}"/>
              <TextBlock Text="Файлы сохраняются в папку atol_output/"
                         FontSize="11" Foreground="{DynamicResource BrushText3}"
                         HorizontalAlignment="Center" Margin="0,8,0,0"/>

            </StackPanel>
          </Border>

          <!-- Skipped rows panel -->
          <Border Background="#1AFF6B00" BorderBrush="#44FF6B00"
                  BorderThickness="1" CornerRadius="10" Padding="16" Margin="0,0,0,14"
                  Visibility="{Binding ShowSkipped, Converter={StaticResource BoolVis}}">
            <StackPanel>
              <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="⚠️" FontSize="14" Margin="0,0,8,0"/>
                <TextBlock Style="{StaticResource SectionTitle}" Margin="0"
                           Text="{Binding SkippedRows.Count, StringFormat='ПРОПУЩЕНО {0} СТРОК — ЧЕКИ УЖЕ ПРОБИТЫ'}"/>
              </StackPanel>
              <TextBlock Text="Для исправления нужны данные из оригинального чека (Такском / 1С). Пробейте вручную."
                         FontSize="12" Foreground="{DynamicResource BrushText2}" Margin="0,0,0,10" TextWrapping="Wrap"/>
              <ItemsControl ItemsSource="{Binding SkippedRows}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Background="{DynamicResource BrushSurface2}"
                            BorderBrush="{DynamicResource BrushBorder}"
                            BorderThickness="1" CornerRadius="6"
                            Padding="10,7" Margin="0,0,0,5">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="Auto" MinWidth="130"/>
                          <ColumnDefinition Width="Auto" MinWidth="90"/>
                          <ColumnDefinition/>
                          <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding OrderNum}"
                                   FontFamily="Courier New" FontSize="12"
                                   Foreground="{DynamicResource BrushAccent2}"/>
                        <TextBlock Grid.Column="1" Text="{Binding OrderDate}"
                                   FontSize="12" Foreground="{DynamicResource BrushText2}"/>
                        <TextBlock Grid.Column="2" Text="{Binding CheckDate, StringFormat='Чек: {0}'}"
                                   FontSize="12" Foreground="{DynamicResource BrushText2}"/>
                        <TextBlock Grid.Column="3"
                                   Text="{Binding Amount, StringFormat={}{0:N2} ₽}"
                                   FontSize="12" FontWeight="SemiBold"/>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

        </StackPanel>

        <!-- ════ РЕЗУЛЬТАТЫ + ПРЕДПРОСМОТР (Row 1, полноширинный мастер-деталь) ════ -->
        <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                Background="{DynamicResource BrushSurface1}"
                BorderBrush="{DynamicResource BrushBorder}"
                BorderThickness="1" CornerRadius="10" Padding="16"
                Margin="0,14,0,0"
                Visibility="{Binding ShowResults, Converter={StaticResource BoolVis}}">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="300"/>   <!-- список файлов -->
              <ColumnDefinition Width="1"/>     <!-- разделитель -->
              <ColumnDefinition Width="*"/>     <!-- предпросмотр -->
            </Grid.ColumnDefinitions>

            <!-- ── Левая панель: список результатов ── -->
            <DockPanel Grid.Column="0" Margin="0,0,16,0">

              <!-- Заголовок -->
              <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                <Border Width="3" Height="13" Background="{DynamicResource BrushAccent}"
                        CornerRadius="2" Margin="0,0,7,0" VerticalAlignment="Center"/>
                <TextBlock Style="{StaticResource SectionTitle}" Margin="0">
                  <Run Text="РЕЗУЛЬТАТЫ"/>
                  <Run Text=" · " Foreground="{DynamicResource BrushText3}"/>
                  <Run Text="{Binding Results.Count, Mode=OneWay}"
                       Foreground="{DynamicResource BrushText3}" FontWeight="Normal"/>
                </TextBlock>
              </StackPanel>

              <!-- Кнопка внизу -->
              <Button DockPanel.Dock="Bottom"
                      Content="📂  Открыть папку с файлами"
                      Style="{StaticResource BtnSecondary}"
                      Margin="0,10,0,0" Padding="0,9"
                      HorizontalAlignment="Stretch"
                      Command="{Binding OpenFolderCommand}"/>

              <!-- Список (прокручиваемый) -->
              <ListBox ItemsSource="{Binding AllResultEntries}"
                       SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                       Background="Transparent"
                       BorderThickness="0"
                       ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                       VirtualizingStackPanel.IsVirtualizing="False">
                <ListBox.ItemContainerStyle>
                  <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin"  Value="0,0,0,8"/>
                    <Setter Property="Cursor"  Value="Hand"/>
                    <Setter Property="Template">
                      <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                          <Border x:Name="card"
                                  Background="{DynamicResource BrushSurface2}"
                                  BorderBrush="{DynamicResource BrushBorder}"
                                  BorderThickness="1.5" CornerRadius="8"
                                  Padding="11">
                            <ContentPresenter/>
                          </Border>
                          <ControlTemplate.Triggers>
                            <!-- Пара исправительных: зелёная рамка -->
                            <DataTrigger Binding="{Binding IsPair}" Value="True">
                              <Setter TargetName="card" Property="BorderBrush" Value="#502DD4A0"/>
                              <Setter TargetName="card" Property="Background"  Value="#0A1A2A1F"/>
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                              <Setter TargetName="card" Property="BorderBrush" Value="{DynamicResource BrushAccent2}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                              <Setter TargetName="card" Property="BorderBrush" Value="{DynamicResource BrushAccent}"/>
                              <Setter TargetName="card" Property="Background"  Value="#12203A"/>
                            </Trigger>
                          </ControlTemplate.Triggers>
                        </ControlTemplate>
                      </Setter.Value>
                    </Setter>
                  </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <Grid>
                      <!-- ── Одиночный чек ── -->
                      <StackPanel>
                        <StackPanel.Style>
                          <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsPair}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </StackPanel.Style>
                        <TextBlock Text="{Binding DisplayOrderNum}"
                                   FontFamily="Courier New" FontSize="12"
                                   Foreground="{DynamicResource BrushAccent2}"
                                   Margin="0,0,0,5"/>
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition/><ColumnDefinition Width="Auto"/>
                          </Grid.ColumnDefinitions>
                          <TextBlock Grid.Column="0" Text="{Binding Single.XmlFilename}"
                                     FontSize="11" Foreground="{DynamicResource BrushText2}"
                                     TextTrimming="CharacterEllipsis"/>
                          <Border Grid.Column="1" Background="#21F0D020"
                                  CornerRadius="3" Padding="5,1" Margin="5,0,0,0">
                            <TextBlock Text="XML" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource BrushYellow}"/>
                          </Border>
                        </Grid>
                        <Grid Margin="0,4,0,0"
                              Visibility="{Binding Single.HasDocx, Converter={StaticResource BoolVis}}">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition/><ColumnDefinition Width="Auto"/>
                          </Grid.ColumnDefinitions>
                          <TextBlock Grid.Column="0" Text="{Binding Single.DocxFilename}"
                                     FontSize="11" Foreground="{DynamicResource BrushText2}"
                                     TextTrimming="CharacterEllipsis"/>
                          <Border Grid.Column="1" Background="#212DD4A0"
                                  CornerRadius="3" Padding="5,1" Margin="5,0,0,0">
                            <TextBlock Text="DOCX" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource BrushGreen}"/>
                          </Border>
                        </Grid>
                      </StackPanel>

                      <!-- ── Исправительная пара ── -->
                      <StackPanel>
                        <StackPanel.Style>
                          <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsPair}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </StackPanel.Style>

                        <!-- Заголовок пары -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,7">
                          <Border Background="#202DD4A0" CornerRadius="4" Padding="5,2" Margin="0,0,7,0">
                            <TextBlock Text="📋 ИСПРАВЛЕНИЕ" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource BrushGreen}"/>
                          </Border>
                          <TextBlock Text="{Binding PairLabel}" FontSize="11"
                                     Foreground="{DynamicResource BrushText3}"
                                     VerticalAlignment="Center"
                                     TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <!-- sell_refund -->
                        <Border Background="#0A2DD4A0" CornerRadius="5" Padding="7,5" Margin="0,0,0,3">
                          <Grid>
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition/><ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                              <TextBlock Text="Возврат прихода" FontSize="10"
                                         Foreground="{DynamicResource BrushGreen}" Margin="0,0,0,2"/>
                              <TextBlock Text="{Binding RefundXmlFilename}" FontSize="11"
                                         Foreground="{DynamicResource BrushText2}"
                                         TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <Border Grid.Column="1" Background="#21F0D020"
                                    CornerRadius="3" Padding="5,1" Margin="5,0,0,0"
                                    VerticalAlignment="Center">
                              <TextBlock Text="XML" FontSize="10" FontWeight="Bold"
                                         Foreground="{DynamicResource BrushYellow}"/>
                            </Border>
                          </Grid>
                        </Border>

                        <!-- sell_correction -->
                        <Border Background="#0A4C8AF5" CornerRadius="5" Padding="7,5">
                          <Grid>
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition/><ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                              <TextBlock Text="Коррекция прихода" FontSize="10"
                                         Foreground="{DynamicResource BrushAccent2}" Margin="0,0,0,2"/>
                              <TextBlock Text="{Binding CorrectionXmlFilename}" FontSize="11"
                                         Foreground="{DynamicResource BrushText2}"
                                         TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <Border Grid.Column="1" Background="#21F0D020"
                                    CornerRadius="3" Padding="5,1" Margin="5,0,0,0"
                                    VerticalAlignment="Center">
                              <TextBlock Text="XML" FontSize="10" FontWeight="Bold"
                                         Foreground="{DynamicResource BrushYellow}"/>
                            </Border>
                          </Grid>
                        </Border>
                      </StackPanel>
                    </Grid>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </DockPanel>

            <!-- ── Вертикальный разделитель ── -->
            <Border Grid.Column="1" Background="{DynamicResource BrushBorder}" Margin="0,2"/>

            <!-- ── Правая панель: предпросмотр выбранного чека ── -->
            <DockPanel Grid.Column="2" Margin="16,0,0,0">
              <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                <Border Width="3" Height="13" Background="{DynamicResource BrushAccent2}"
                        CornerRadius="2" Margin="0,0,7,0" VerticalAlignment="Center"/>
                <TextBlock Text="ПРЕДПРОСМОТР ЧЕКА" Style="{StaticResource SectionTitle}" Margin="0"/>
              </StackPanel>

              <!-- Подсказка, если ничего не выбрано -->
              <TextBlock DockPanel.Dock="Top"
                         Text="Выберите чек из списка слева"
                         FontSize="13" Foreground="{DynamicResource BrushText3}"
                         HorizontalAlignment="Center" Margin="0,40,0,0">
                <TextBlock.Style>
                  <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding SelectedEntry}" Value="{x:Null}">
                        <Setter Property="Visibility" Value="Visible"/>
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </TextBlock.Style>
              </TextBlock>

              <!-- Кассовая лента -->
              <Border Background="{DynamicResource BrushSurface2}"
                      BorderBrush="{DynamicResource BrushBorder}"
                      BorderThickness="1" CornerRadius="7" Padding="14">
                <Border.Style>
                  <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding SelectedEntry}" Value="{x:Null}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Border.Style>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto">
                  <TextBlock Text="{Binding SelectedReceiptPreview}"
                             FontFamily="Courier New" FontSize="12.5"
                             Foreground="{DynamicResource BrushText2}"
                             TextWrapping="NoWrap" LineHeight="20"/>
                </ScrollViewer>
              </Border>
            </DockPanel>
          </Grid>
        </Border>

        <!-- ════ 1С РЕАЛИЗАЦИИ — полноширинная таблица ════ -->
        <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                Background="{DynamicResource BrushSurface1}"
                BorderBrush="{DynamicResource BrushBorder}"
                BorderThickness="1" CornerRadius="10" Padding="16"
                Margin="0,14,0,0"
                Visibility="{Binding ShowLoadedRealizations, Converter={StaticResource BoolVis}}">
          <StackPanel>

            <!-- Заголовок + кнопки -->
            <Grid Margin="0,0,0,12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>

              <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="3" Height="13" Background="{DynamicResource BrushAccent}"
                        CornerRadius="2" Margin="0,0,7,0"/>
                <TextBlock Style="{StaticResource SectionTitle}" Margin="0">
                  <Run Text="РЕАЛИЗАЦИИ ИЗ 1С"/>
                </TextBlock>
                <TextBlock FontSize="12" Foreground="{DynamicResource BrushText3}" Margin="8,0,0,0"
                           VerticalAlignment="Center">
                  <Run Text="{Binding TotalOneCLoaded, Mode=OneWay}"/>
                  <Run Text=" записей · выбрано: "/>
                  <Run Text="{Binding SelectedOneCCount, Mode=OneWay}" FontWeight="Bold"
                       Foreground="{DynamicResource BrushAccent2}"/>
                </TextBlock>
              </StackPanel>

              <WrapPanel Grid.Column="2" Orientation="Horizontal">
                <Button Content="Выбрать все"
                        Style="{StaticResource BtnGhost}"
                        Padding="10,5" FontSize="12" Margin="0,0,6,0"
                        Command="{Binding SelectAllOneCCommand}"/>
                <Button Content="Снять все"
                        Style="{StaticResource BtnGhost}"
                        Padding="10,5" FontSize="12" Margin="0,0,6,0"
                        Command="{Binding DeselectAllOneCCommand}"/>
                <Button Style="{StaticResource BtnPrimary}"
                        Padding="12,5" FontSize="12" Margin="0,0,6,0"
                        Command="{Binding AddSelectedToOrdersCommand}"
                        IsEnabled="{Binding SelectedOneCCount, Converter={StaticResource NonZeroBool}}"
                        ToolTip="Добавляет выбранные реализации в основной список как чеки коррекции «Чек не пробит».">
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Text="➕  Добавить выбранные (" Margin="0"/>
                    <TextBlock Text="{Binding SelectedOneCCount, Mode=OneWay}" FontWeight="Bold"/>
                    <TextBlock Text=")" Margin="0"/>
                  </StackPanel>
                </Button>
                <Button Padding="12,5" FontSize="12"
                        Command="{Binding PunchViaAtolCommand}"
                        IsEnabled="{Binding CanPunchSelectedRealizationsViaAtol}"
                        ToolTip="Редкий режим: пробивает выбранные реализации без чека как обычный «Приход» через АТОЛ Online. Доступно только когда выбран тип чека «Приход». Для коррекций используйте XML.">
                  <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
                      <Setter Property="Background" Value="#CC2244AA"/>
                      <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                          <Setter Property="Background" Value="#CC3355CC"/>
                        </Trigger>
                      </Style.Triggers>
                    </Style>
                  </Button.Style>
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🔥  Пробить через АТОЛ (" Margin="0"/>
                    <TextBlock Text="{Binding SelectedNoCheckCount, Mode=OneWay}" FontWeight="Bold"/>
                    <TextBlock Text=")" Margin="0"/>
                  </StackPanel>
                </Button>

              </WrapPanel>
            </Grid>

            <!-- DataGrid -->
            <DataGrid ItemsSource="{Binding LoadedRealizations}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserReorderColumns="False"
                      CanUserResizeRows="False"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      RowHeaderWidth="0"
                      MaxHeight="420"
                      BorderThickness="1"
                      BorderBrush="{DynamicResource BrushBorder}"
                      Background="{DynamicResource BrushSurface2}"
                      RowBackground="{DynamicResource BrushSurface1}"
                      AlternatingRowBackground="{DynamicResource BrushSurface2}"
                      Foreground="{DynamicResource BrushText}"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">

              <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                  <Setter Property="Background"   Value="{DynamicResource BrushSurface2}"/>
                  <Setter Property="Foreground"   Value="{DynamicResource BrushText3}"/>
                  <Setter Property="FontSize"     Value="11"/>
                  <Setter Property="FontWeight"   Value="Bold"/>
                  <Setter Property="Padding"      Value="8,6"/>
                  <Setter Property="BorderBrush"  Value="{DynamicResource BrushBorder}"/>
                  <Setter Property="BorderThickness" Value="0,0,0,1"/>
                </Style>
                <Style TargetType="DataGridCell">
                  <Setter Property="BorderThickness" Value="0"/>
                  <Setter Property="Padding"         Value="8,5"/>
                  <Setter Property="Template">
                    <Setter.Value>
                      <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}">
                          <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                      </ControlTemplate>
                    </Setter.Value>
                  </Setter>
                </Style>
              </DataGrid.Resources>

              <!-- Строки: уже пробитые — тонкий зелёный тон (теперь интерактивны для исправлений) -->
              <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                  <Setter Property="Background" Value="Transparent"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding HasCheck}" Value="True">
                      <Setter Property="Background" Value="#0A2DD4A0"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </DataGrid.RowStyle>

              <DataGrid.Columns>

                <!-- Галочка -->
                <DataGridTemplateColumn Width="36" CanUserSort="False">
                  <DataGridTemplateColumn.Header>
                    <TextBlock Text="✓" FontSize="12" HorizontalAlignment="Center"/>
                  </DataGridTemplateColumn.Header>
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Реализация -->
                <DataGridTextColumn Header="Реализация" Binding="{Binding DocNumber}"
                                    Width="130" IsReadOnly="True"
                                    ElementStyle="{StaticResource DataGridTextStyle}"/>

                <!-- Дата -->
                <DataGridTextColumn Header="Дата" Binding="{Binding DocDate}"
                                    Width="88" IsReadOnly="True"
                                    ElementStyle="{StaticResource DataGridTextStyle}"/>

                <!-- Заказ -->
                <DataGridTextColumn Header="Заказ покупателя" Binding="{Binding OrderNumber}"
                                    Width="130" IsReadOnly="True"
                                    ElementStyle="{StaticResource DataGridTextStyle}"/>

                <!-- Покупатель -->
                <DataGridTextColumn Header="Покупатель" Binding="{Binding CustomerName}"
                                    Width="*" IsReadOnly="True"
                                    ElementStyle="{StaticResource DataGridTextStyle}"/>

                <!-- Город -->
                <DataGridTextColumn Header="Город" Binding="{Binding City}"
                                    Width="110" IsReadOnly="True"
                                    ElementStyle="{StaticResource DataGridTextStyle}"/>

                <!-- Сумма -->
                <DataGridTextColumn Header="Сумма, ₽"
                                    Binding="{Binding Amount, StringFormat={}{0:N2}}"
                                    Width="90" IsReadOnly="True">
                  <DataGridTextColumn.ElementStyle>
                    <Style TargetType="TextBlock">
                      <Setter Property="FontWeight"         Value="SemiBold"/>
                      <Setter Property="HorizontalAlignment" Value="Right"/>
                      <Setter Property="Foreground"         Value="{DynamicResource BrushGreen}"/>
                      <Setter Property="Padding"            Value="0,0,8,0"/>
                    </Style>
                  </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Номер чека ККМ -->
                <DataGridTextColumn Header="№ чека ККМ" Binding="{Binding CheckNumber}"
                                    Width="110" IsReadOnly="True"
                                    ElementStyle="{StaticResource DataGridTextStyle}"/>

                <!-- Номер ФП -->
                <DataGridTextColumn Header="№ ФП" Binding="{Binding FiscalNumber}"
                                    Width="110" IsReadOnly="True"
                                    ElementStyle="{StaticResource DataGridTextStyle}"/>

                <!-- Агент -->
                <DataGridTemplateColumn Header="Агент" Width="52" CanUserSort="False">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <TextBlock HorizontalAlignment="Center" FontSize="13"
                                 ToolTip="Агентский договор (НДС: нет)">
                        <TextBlock.Style>
                          <Style TargetType="TextBlock">
                            <Setter Property="Text"       Value=""/>
                            <Setter Property="Foreground" Value="Transparent"/>
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsService}" Value="True">
                                <Setter Property="Text"       Value="🔧"/>
                                <Setter Property="Foreground" Value="{DynamicResource BrushText}"/>
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </TextBlock.Style>
                      </TextBlock>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Чек -->
                <DataGridTemplateColumn Header="Чек" Width="58" CanUserSort="False">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                              CornerRadius="4" Padding="5,2">
                        <Border.Style>
                          <Style TargetType="Border">
                            <Setter Property="Background"  Value="#1A4C8AF5"/>
                            <Setter Property="Visibility"  Value="Collapsed"/>
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding HasCheck}" Value="True">
                                <Setter Property="Background" Value="#1AFF4444"/>
                                <Setter Property="Visibility" Value="Visible"/>
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </Border.Style>
                        <TextBlock Text="пробит" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource BrushRed}"
                                   ToolTip="{Binding CheckDate}"/>
                      </Border>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Статус пробития -->
                <DataGridTemplateColumn Header="АТОЛ" Width="130" CanUserSort="False">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <Border CornerRadius="4" Padding="5,2" HorizontalAlignment="Left"
                              VerticalAlignment="Center">
                        <Border.Style>
                          <Style TargetType="Border">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding PunchOk}" Value="True">
                                <Setter Property="Background" Value="#1A44FF44"/>
                              </DataTrigger>
                              <DataTrigger Binding="{Binding PunchFail}" Value="True">
                                <Setter Property="Background" Value="#1AFF4444"/>
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding PunchStatus}" FontSize="11"
                                   TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding PunchStatus}">
                          <TextBlock.Style>
                            <Style TargetType="TextBlock">
                              <Setter Property="Foreground" Value="{DynamicResource BrushText3}"/>
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding PunchOk}" Value="True">
                                  <Setter Property="Foreground" Value="{DynamicResource BrushGreen}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding PunchFail}" Value="True">
                                  <Setter Property="Foreground" Value="{DynamicResource BrushRed}"/>
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </TextBlock.Style>
                        </TextBlock>
                      </Border>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

              </DataGrid.Columns>
            </DataGrid>

          </StackPanel>
        </Border>

      </Grid>
    </ScrollViewer>

    <Grid Grid.Row="1" Grid.Column="1"
          Visibility="{Binding ShowReportsWorkspace, Converter={StaticResource BoolVis}}">
      <views:ReportsView DataContext="{Binding Reports}"/>
    </Grid>

    <Grid Grid.Row="1" Grid.Column="1"
          Visibility="{Binding ShowObsidianWorkspace, Converter={StaticResource BoolVis}}">
      <views:ObsidianCasesView DataContext="{Binding ObsidianCases}"/>
    </Grid>

    <!-- ══════════ STATUS BAR ══════════ -->
    <Border Grid.Row="2" Grid.Column="1"
            Background="{DynamicResource BrushSurface1}"
            BorderBrush="{DynamicResource BrushBorder}"
            BorderThickness="0,1,0,0">
      <Grid Margin="22,0">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <Ellipse Width="7" Height="7" Fill="{DynamicResource BrushGreen}">
            <Ellipse.Effect>
              <DropShadowEffect Color="{StaticResource ColorGreen}" BlurRadius="5"
                                ShadowDepth="0" Opacity="1"/>
            </Ellipse.Effect>
          </Ellipse>
          <TextBlock Text="{Binding StatusText}" Margin="10,0,0,0"
                     FontSize="12" Foreground="{DynamicResource BrushText2}"/>
        </StackPanel>
        <TextBlock Text="ИНН 352526561274 · https://alleyadoma.ru"
                   FontSize="12" Foreground="{DynamicResource BrushText3}"
                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
      </Grid>
    </Border>

    <!-- ══════════ TOAST ══════════ -->
    <Border Grid.Row="1" Grid.Column="1"
            HorizontalAlignment="Right" VerticalAlignment="Top"
            Margin="0,14,18,0" MaxWidth="320"
            Visibility="{Binding ToastVisible, Converter={StaticResource BoolVis}}"
            Panel.ZIndex="999">
      <Border Background="{DynamicResource BrushSurface2}"
              BorderThickness="1" CornerRadius="9"
              Padding="15,10">
        <Border.Style>
          <Style TargetType="Border">
            <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}"/>
            <Style.Triggers>
              <DataTrigger Binding="{Binding ToastIsError}" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource BrushRed}"/>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
        <Border.Effect>
          <DropShadowEffect BlurRadius="28" ShadowDepth="4" Opacity="0.5" Color="#000000"/>
        </Border.Effect>
        <TextBlock Text="{Binding ToastMessage}"
                   FontSize="13" Foreground="{DynamicResource BrushText}"
                   TextWrapping="Wrap"/>
      </Border>
    </Border>

  </Grid>
</Window>
