<Window x:Class="AtolGenerator.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:cv="clr-namespace:AtolGenerator.Views.Converters"
        Title="Настройки"
        Icon="/Resources/app.ico"
        Width="1180" Height="760"
        MinWidth="980" MinHeight="680"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BrushBg}">

  <Window.Resources>
    <cv:BoolToVisibilityConverter x:Key="BoolVis"/>
    <cv:StringEqualConverter x:Key="StrEq"/>

    <Style x:Key="SettingsNav" TargetType="ToggleButton">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="{DynamicResource BrushText2}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="13,11"/>
      <Setter Property="Margin" Value="0,0,0,5"/>
      <Setter Property="HorizontalContentAlignment" Value="Left"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ToggleButton">
            <Border x:Name="border" Background="{TemplateBinding Background}"
                    CornerRadius="6" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="border" Property="Background" Value="{DynamicResource BrushSurface3}"/>
              </Trigger>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="border" Property="Background" Value="{DynamicResource BrushSurface3}"/>
                <Setter Property="Foreground" Value="{DynamicResource BrushAccent}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="ThemeChoice" TargetType="ListBoxItem">
      <Setter Property="Margin" Value="0,0,12,0"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ListBoxItem">
            <Border x:Name="choice" Background="{DynamicResource BrushSurface1}"
                    BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                    CornerRadius="8" Padding="15" Cursor="Hand">
              <ContentPresenter/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="choice" Property="BorderBrush" Value="{DynamicResource BrushAccent}"/>
              </Trigger>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="choice" Property="BorderBrush" Value="{DynamicResource BrushAccent}"/>
                <Setter TargetName="choice" Property="BorderThickness" Value="2"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="SettingsGrid" TargetType="DataGrid">
      <Setter Property="AutoGenerateColumns" Value="False"/>
      <Setter Property="CanUserAddRows" Value="False"/>
      <Setter Property="CanUserDeleteRows" Value="False"/>
      <Setter Property="CanUserResizeRows" Value="False"/>
      <Setter Property="HeadersVisibility" Value="Column"/>
      <Setter Property="GridLinesVisibility" Value="Horizontal"/>
      <Setter Property="RowHeaderWidth" Value="0"/>
      <Setter Property="Background" Value="{DynamicResource BrushSurface1}"/>
      <Setter Property="RowBackground" Value="{DynamicResource BrushSurface1}"/>
      <Setter Property="AlternatingRowBackground" Value="{DynamicResource BrushSurface2}"/>
      <Setter Property="Foreground" Value="{DynamicResource BrushText}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="SelectionMode" Value="Single"/>
      <Setter Property="SelectionUnit" Value="FullRow"/>
      <Setter Property="RowHeight" Value="36"/>
      <Setter Property="ColumnHeaderHeight" Value="38"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
      <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
    </Style>
  </Window.Resources>

  <Grid Background="{DynamicResource BrushBg}">
    <Grid.RowDefinitions>
      <RowDefinition Height="72"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="66"/>
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="220"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <Border Grid.Row="0" Grid.ColumnSpan="2"
            Background="{DynamicResource BrushSurface1}"
            BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,0,0,1">
      <Grid Margin="24,0">
        <StackPanel VerticalAlignment="Center">
          <TextBlock Text="Настройки" FontSize="22" FontWeight="SemiBold"/>
          <TextBlock Text="Подключения, оформление и правила формирования чеков"
                     Foreground="{DynamicResource BrushText3}" FontSize="12" Margin="0,4,0,0"/>
        </StackPanel>
      </Grid>
    </Border>

    <Border Grid.Row="1" Grid.Column="0"
            Background="{DynamicResource BrushSurface2}"
            BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,0,1,0">
      <StackPanel Margin="16,20">
        <TextBlock Text="РАЗДЕЛЫ" Style="{StaticResource SectionTitle}"/>
        <ToggleButton Style="{StaticResource SettingsNav}"
                      IsChecked="{Binding Section, Mode=OneWay, Converter={StaticResource StrEq}, ConverterParameter=connections}"
                      Command="{Binding SelectSectionCommand}" CommandParameter="connections"
                      Content="⇄  Подключения"/>
        <ToggleButton Style="{StaticResource SettingsNav}"
                      IsChecked="{Binding Section, Mode=OneWay, Converter={StaticResource StrEq}, ConverterParameter=appearance}"
                      Command="{Binding SelectSectionCommand}" CommandParameter="appearance"
                      Content="◐  Оформление"/>
        <ToggleButton Style="{StaticResource SettingsNav}"
                      IsChecked="{Binding Section, Mode=OneWay, Converter={StaticResource StrEq}, ConverterParameter=cashiers}"
                      Command="{Binding SelectSectionCommand}" CommandParameter="cashiers"
                      Content="♙  Кассиры"/>
        <ToggleButton Style="{StaticResource SettingsNav}"
                      IsChecked="{Binding Section, Mode=OneWay, Converter={StaticResource StrEq}, ConverterParameter=agents}"
                      Command="{Binding SelectSectionCommand}" CommandParameter="agents"
                      Content="⌘  Агенты"/>
        <ToggleButton Style="{StaticResource SettingsNav}"
                      IsChecked="{Binding Section, Mode=OneWay, Converter={StaticResource StrEq}, ConverterParameter=obsidian}"
                      Command="{Binding SelectSectionCommand}" CommandParameter="obsidian"
                      Content="▧  Obsidian"/>
        <Border Height="1" Background="{DynamicResource BrushBorder}" Margin="4,10,4,14"/>
        <ToggleButton Style="{StaticResource SettingsNav}"
                      IsChecked="{Binding Section, Mode=OneWay, Converter={StaticResource StrEq}, ConverterParameter=about}"
                      Command="{Binding SelectSectionCommand}" CommandParameter="about"
                      Content="ⓘ  О программе"/>
        <TextBlock Text="{Binding VersionText}" Margin="13,8,0,0"
                   Foreground="{DynamicResource BrushText3}" FontSize="11"/>
      </StackPanel>
    </Border>

    <Grid Grid.Row="1" Grid.Column="1">
      <!-- Подключения -->
      <ScrollViewer Visibility="{Binding ShowConnections, Converter={StaticResource BoolVis}}"
                    VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,22">
          <TextBlock Text="Подключения" FontSize="19" FontWeight="SemiBold"/>
          <TextBlock Text="Данные сохраняются в существующих файлах рядом с программой."
                     Foreground="{DynamicResource BrushText3}" FontSize="12" Margin="0,5,0,20"/>

          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition/>
              <ColumnDefinition Width="16"/>
              <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="18">
              <StackPanel>
                <TextBlock Text="АТОЛ Online" FontSize="15" FontWeight="SemiBold"/>
                <TextBlock Text="Авторизация и группа ККТ для API"
                           Style="{StaticResource HintText}" Margin="0,4,0,16"/>
                <TextBlock Text="Логин" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding AtolLogin, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,11"/>
                <TextBlock Text="Пароль" Style="{StaticResource FieldLabel}"/>
                <PasswordBox cv:PasswordHelper.Attach="True"
                             cv:PasswordHelper.Password="{Binding AtolPassword, Mode=TwoWay}"
                             Margin="0,0,0,11"/>
                <TextBlock Text="Код группы" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding AtolGroupCode, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15"/>
                <Button Content="Проверить подключение" Style="{StaticResource BtnSecondary}"
                        Command="{Binding TestAtolCommand}" HorizontalAlignment="Left"/>
                <TextBlock Text="{Binding AtolStatus}" Style="{StaticResource HintText}"/>
              </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource Card}" Padding="18">
              <StackPanel>
                <TextBlock Text="1С:Предприятие" FontSize="15" FontWeight="SemiBold"/>
                <TextBlock Text="COM-подключение к информационной базе"
                           Style="{StaticResource HintText}" Margin="0,4,0,16"/>
                <Grid Margin="0,0,0,11">
                  <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/></Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0">
                    <TextBlock Text="Сервер" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding OneCServer, UpdateSourceTrigger=PropertyChanged}"/>
                  </StackPanel>
                  <StackPanel Grid.Column="2">
                    <TextBlock Text="База (Ref)" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding OneCDatabase, UpdateSourceTrigger=PropertyChanged}"/>
                  </StackPanel>
                </Grid>
                <TextBlock Text="Пользователь" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding OneCUser, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,11"/>
                <TextBlock Text="Пароль" Style="{StaticResource FieldLabel}"/>
                <PasswordBox cv:PasswordHelper.Attach="True"
                             cv:PasswordHelper.Password="{Binding OneCPassword, Mode=TwoWay}"
                             Margin="0,0,0,15"/>
                <Button Content="Проверить подключение" Style="{StaticResource BtnSecondary}"
                        Command="{Binding TestOneCCommand}" HorizontalAlignment="Left"/>
                <TextBlock Text="{Binding OneCStatus}" Style="{StaticResource HintText}"/>
              </StackPanel>
            </Border>
          </Grid>
        </StackPanel>
      </ScrollViewer>

      <!-- Оформление -->
      <ScrollViewer Visibility="{Binding ShowAppearance, Converter={StaticResource BoolVis}}"
                    VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,22">
          <TextBlock Text="Оформление" FontSize="19" FontWeight="SemiBold"/>
          <TextBlock Text="Тема применяется сразу ко всем открытым окнам."
                     Foreground="{DynamicResource BrushText3}" FontSize="12" Margin="0,5,0,20"/>
          <ListBox ItemsSource="{Binding ThemeOptions}" SelectedItem="{Binding SelectedTheme}"
                   BorderThickness="0" Background="Transparent"
                   ItemContainerStyle="{StaticResource ThemeChoice}">
            <ListBox.ItemsPanel>
              <ItemsPanelTemplate><UniformGrid Columns="3"/></ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
              <DataTemplate>
                <StackPanel>
                  <Border Height="92" Background="{Binding Background}" CornerRadius="6" Padding="10">
                    <Grid>
                      <Border Width="76" HorizontalAlignment="Left" Background="{Binding Surface}" CornerRadius="5"/>
                      <Border Width="46" Height="8" Background="{Binding Accent}" CornerRadius="3"
                              HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,10,7,0"/>
                      <Border Width="72" Height="28" Background="{Binding Accent}" CornerRadius="5"
                              HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,7,8"/>
                    </Grid>
                  </Border>
                  <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" Margin="0,12,0,0"/>
                  <TextBlock Text="{Binding Description}" Foreground="{DynamicResource BrushText3}"
                             FontSize="11" Margin="0,3,0,0" TextWrapping="Wrap"/>
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </StackPanel>
      </ScrollViewer>

      <!-- Кассиры -->
      <Grid Visibility="{Binding ShowCashiers, Converter={StaticResource BoolVis}}" Margin="24,22">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Margin="0,0,0,18">
          <StackPanel>
            <TextBlock Text="Кассиры" FontSize="19" FontWeight="SemiBold"/>
            <TextBlock Text="Данные используются в чеках и служебных записках."
                       Foreground="{DynamicResource BrushText3}" FontSize="12" Margin="0,5,0,0"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
            <Button Content="Добавить" Style="{StaticResource BtnSecondary}" Command="{Binding AddCashierCommand}"/>
            <Button Content="Удалить" Style="{StaticResource BtnDelete}" Width="72" Margin="8,0,0,0"
                    Command="{Binding DeleteCashierCommand}"/>
          </StackPanel>
        </Grid>
        <Grid Grid.Row="1" Margin="0,0,0,14">
          <Grid.ColumnDefinitions><ColumnDefinition Width="190"/><ColumnDefinition Width="360"/><ColumnDefinition/></Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="Кассир по умолчанию" Style="{StaticResource FieldLabel}"
                     VerticalAlignment="Center" Margin="0,0,10,0"/>
          <ComboBox Grid.Column="1" ItemsSource="{Binding Cashiers}" SelectedItem="{Binding DefaultCashier}"
                    DisplayMemberPath="Display"/>
        </Grid>
        <DataGrid Grid.Row="2" Style="{StaticResource SettingsGrid}"
                  ItemsSource="{Binding Cashiers}" SelectedItem="{Binding SelectedCashier}"
                  MinHeight="360">
          <DataGrid.Columns>
            <DataGridTextColumn Header="Короткое имя" Binding="{Binding ShortName, UpdateSourceTrigger=PropertyChanged}" Width="150"/>
            <DataGridTextColumn Header="ФИО и должность в чеке" Binding="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" Width="360"/>
            <DataGridTextColumn Header="Должность для служебки" Binding="{Binding Position, UpdateSourceTrigger=PropertyChanged}" Width="250"/>
            <DataGridTextColumn Header="ФИО в родительном падеже" Binding="{Binding NameGenitive, UpdateSourceTrigger=PropertyChanged}" Width="280"/>
            <DataGridTextColumn Header="Название в списке" Binding="{Binding Display, UpdateSourceTrigger=PropertyChanged}" Width="310"/>
          </DataGrid.Columns>
        </DataGrid>
      </Grid>

      <!-- Агенты -->
      <Grid Visibility="{Binding ShowAgents, Converter={StaticResource BoolVis}}" Margin="24,22">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Margin="0,0,0,18">
          <StackPanel>
            <TextBlock Text="Правила агентов" FontSize="19" FontWeight="SemiBold"/>
            <TextBlock Text="Одно правило связывает услугу и подразделение 1С с агентом и ставкой НДС."
                       Foreground="{DynamicResource BrushText3}" FontSize="12" Margin="0,5,0,0"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
            <Button Content="Добавить правило" Style="{StaticResource BtnSecondary}" Command="{Binding AddAgentCommand}"/>
            <Button Content="Удалить" Style="{StaticResource BtnDelete}" Width="72" Margin="8,0,0,0"
                    Command="{Binding DeleteAgentCommand}"/>
          </StackPanel>
        </Grid>
        <DataGrid Grid.Row="1" Style="{StaticResource SettingsGrid}"
                  ItemsSource="{Binding Agents}" SelectedItem="{Binding SelectedAgent}"
                  MinHeight="420">
          <DataGrid.Columns>
            <DataGridTemplateColumn Header="Услуга" Width="110">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate><TextBlock Text="{Binding Service}" VerticalAlignment="Center"/></DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
              <DataGridTemplateColumn.CellEditingTemplate>
                <DataTemplate>
                  <ComboBox ItemsSource="{Binding DataContext.ServiceTypes, RelativeSource={RelativeSource AncestorType=Window}}"
                            SelectedItem="{Binding Service, UpdateSourceTrigger=PropertyChanged}"/>
                </DataTemplate>
              </DataGridTemplateColumn.CellEditingTemplate>
            </DataGridTemplateColumn>
            <DataGridTextColumn Header="Подразделение 1С" Binding="{Binding City, UpdateSourceTrigger=PropertyChanged}" Width="150"/>
            <DataGridTextColumn Header="Агент / поставщик" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="2*"/>
            <DataGridTextColumn Header="ИНН" Binding="{Binding Inn, UpdateSourceTrigger=PropertyChanged}" Width="125"/>
            <DataGridTextColumn Header="Телефон" Binding="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" Width="130"/>
            <DataGridTemplateColumn Header="НДС" Width="90">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate><TextBlock Text="{Binding VatType}" VerticalAlignment="Center"/></DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
              <DataGridTemplateColumn.CellEditingTemplate>
                <DataTemplate>
                  <ComboBox ItemsSource="{Binding DataContext.VatTypes, RelativeSource={RelativeSource AncestorType=Window}}"
                            SelectedItem="{Binding VatType, UpdateSourceTrigger=PropertyChanged}"/>
                </DataTemplate>
              </DataGridTemplateColumn.CellEditingTemplate>
            </DataGridTemplateColumn>
          </DataGrid.Columns>
        </DataGrid>
      </Grid>

      <!-- Obsidian -->
      <ScrollViewer Visibility="{Binding ShowObsidian, Converter={StaticResource BoolVis}}"
                    VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,22" MaxWidth="760" HorizontalAlignment="Left">
          <TextBlock Text="Obsidian" FontSize="19" FontWeight="SemiBold"/>
          <TextBlock Text="Связь с рабочим журналом ошибок чеков."
                     Foreground="{DynamicResource BrushText3}" FontSize="12" Margin="0,5,0,20"/>

          <Border Style="{StaticResource Card}" Padding="18">
            <StackPanel>
              <TextBlock Text="Файл задач" FontSize="15" FontWeight="SemiBold"/>
              <TextBlock Text="Программа читает изменения файла и отмечает закрытые случаи автоматически."
                         Style="{StaticResource HintText}" Margin="0,4,0,14" TextWrapping="Wrap"/>
              <TextBlock Text="Путь к Markdown-файлу" Style="{StaticResource FieldLabel}"/>
              <Grid Margin="0,0,0,18">
                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <TextBox Text="{Binding ObsidianFilePath, UpdateSourceTrigger=PropertyChanged}"
                         IsReadOnly="True" MinWidth="560"/>
                <Button Grid.Column="1" Content="Выбрать..." Style="{StaticResource BtnSecondary}"
                        Margin="8,0,0,0" Command="{Binding BrowseObsidianFileCommand}"/>
              </Grid>
              <CheckBox Content="Автоматически проверять созданные служебные записки"
                        IsChecked="{Binding AutoValidateServiceNotes}"
                        FontWeight="SemiBold"/>
              <TextBlock Text="Если выключено, служебки проверяются выбранными строками на экране Obsidian."
                         Style="{StaticResource HintText}" Margin="24,5,0,0" TextWrapping="Wrap"/>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <!-- О программе -->
      <ScrollViewer Visibility="{Binding ShowAbout, Converter={StaticResource BoolVis}}"
                    VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,22" MaxWidth="790" HorizontalAlignment="Left">
          <TextBlock Text="О программе" FontSize="19" FontWeight="SemiBold"/>
          <TextBlock Text="Версия, назначение и обновления приложения."
                     Foreground="{DynamicResource BrushText3}" FontSize="12" Margin="0,5,0,20"/>

          <Border Style="{StaticResource Card}" Padding="20">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="72"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <Border Width="58" Height="58" CornerRadius="8"
                      Background="{DynamicResource BrushSurface3}"
                      BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                      VerticalAlignment="Top">
                <Image Source="/Resources/app.ico" Width="38" Height="38"/>
              </Border>
              <StackPanel Grid.Column="1">
                <TextBlock Text="{Binding ApplicationName}" FontSize="20" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding VersionText}" Foreground="{DynamicResource BrushAccent}"
                           FontSize="13" FontWeight="SemiBold" Margin="0,4,0,0"/>
                <TextBlock Text="Рабочее приложение для формирования возвратов через АТОЛ API, подготовки XML чеков коррекции по данным 1С и сверки фискальных отчётов."
                           Foreground="{DynamicResource BrushText2}" FontSize="13"
                           TextWrapping="Wrap" LineHeight="20" Margin="0,14,0,0"/>
              </StackPanel>
            </Grid>
          </Border>

          <Border Margin="0,16,0,0" Padding="20"
                  Background="{DynamicResource BrushSurface2}"
                  BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                  CornerRadius="7">
            <StackPanel>
              <TextBlock Text="Обновления" FontSize="15" FontWeight="SemiBold"/>
              <TextBlock Text="При запуске программа проверяет последний опубликованный выпуск на GitHub. Проверку можно повторить вручную."
                         Style="{StaticResource HintText}" Margin="0,5,0,14" TextWrapping="Wrap"/>
              <TextBlock Text="{Binding UpdateStatus}" Foreground="{DynamicResource BrushText2}"
                         FontSize="12" Margin="0,0,0,14" TextWrapping="Wrap"/>
              <StackPanel Orientation="Horizontal">
                <Button Content="Проверить обновления" Style="{StaticResource BtnSecondary}"
                        Command="{Binding CheckForUpdatesCommand}"/>
                <Button Content="Скачать обновление" Style="{StaticResource BtnPrimary}"
                        Command="{Binding OpenUpdateCommand}" Margin="8,0,0,0"
                        Visibility="{Binding HasUpdateAvailable, Converter={StaticResource BoolVis}}"/>
              </StackPanel>
            </StackPanel>
          </Border>

          <Grid Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
              <TextBlock Text="Исходный код и выпуски" FontSize="14" FontWeight="SemiBold"/>
              <TextBlock Text="{Binding RepositoryText}" Style="{StaticResource HintText}" Margin="0,4,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Content="Открыть GitHub" Style="{StaticResource BtnSecondary}"
                    Command="{Binding OpenRepositoryCommand}" VerticalAlignment="Center"/>
          </Grid>
        </StackPanel>
      </ScrollViewer>
    </Grid>

    <Border Grid.Row="2" Grid.ColumnSpan="2"
            Background="{DynamicResource BrushSurface1}"
            BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,1,0,0">
      <Grid Margin="24,0">
        <TextBlock Text="{Binding ValidationMessage}" Foreground="{DynamicResource BrushRed}"
                   Visibility="{Binding HasValidationMessage, Converter={StaticResource BoolVis}}"
                   VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,250,0"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
          <Button Content="Отмена" Style="{StaticResource BtnSecondary}" Command="{Binding CancelCommand}" MinWidth="92"/>
          <Button Content="Сохранить" Style="{StaticResource BtnPrimary}" Command="{Binding SaveCommand}"
                  MinWidth="110" Margin="10,0,0,0"/>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
