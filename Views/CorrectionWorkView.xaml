<UserControl x:Class="AtolGenerator.Views.CorrectionWorkView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cv="clr-namespace:AtolGenerator.Views.Converters"
             Background="{DynamicResource BrushBg}"
             Foreground="{DynamicResource BrushText}"
             FontFamily="Segoe UI" FontSize="13">
    <UserControl.Resources>
        <cv:BoolToVisibilityConverter x:Key="BoolVis"/>

        <Style x:Key="MetaLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushText3}"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>

        <Style x:Key="SelectableValue" TargetType="TextBox">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="IsTabStop" Value="False"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{DynamicResource BrushBorder}"
                                BorderThickness="1" CornerRadius="7"
                                Padding="12">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource BrushAccent}"/>
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource BrushSurface2}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource BrushAccent}"/>
                                <Setter TargetName="ItemBorder" Property="BorderThickness" Value="2"/>
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource BrushSurface2}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource BrushAccent2}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24,18,24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Пробитие исправлений" FontSize="25" FontWeight="Bold"/>
                    <Border Background="{DynamicResource BrushSurface3}" CornerRadius="5"
                            Padding="8,4" Margin="10,2,0,0" VerticalAlignment="Top">
                        <TextBlock Text="ФФД 1.05 · XML" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource BrushAccent2}"/>
                    </Border>
                </StackPanel>
                <TextBlock Text="Официальная схема АТОЛ: отмена ошибочного чека и правильный чек готовятся отдельно."
                           FontSize="13" Foreground="{DynamicResource BrushText2}" Margin="0,4,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock TextAlignment="Right" Foreground="{DynamicResource BrushText2}">
                    <Run Text="В списке: "/><Run Text="{Binding ItemCount, Mode=OneWay}" FontWeight="Bold"/>
                    <Run Text="  ·  готово: "/><Run Text="{Binding ReadyCount, Mode=OneWay}" FontWeight="Bold"/>
                </TextBlock>
                <TextBlock Text="Через API эти чеки не отправляются"
                           Foreground="{DynamicResource BrushOrange}" FontSize="12" Margin="0,3,0,0"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Background="{DynamicResource BrushSurface2}"
                BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                CornerRadius="7" Padding="10" Margin="0,0,0,12">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Button Content="← К списку ошибок" Style="{StaticResource BtnSecondary}"
                            Command="{Binding BackCommand}" Margin="0,0,8,0"/>
                    <Button Content="Выбрать все" Style="{StaticResource BtnSecondary}"
                            Command="{Binding SelectAllCommand}" Margin="0,0,8,0"/>
                    <Button Content="Снять выбор" Style="{StaticResource BtnSecondary}"
                            Command="{Binding DeselectAllCommand}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Открыть папку" Style="{StaticResource BtnSecondary}"
                            Command="{Binding OpenFolderCommand}" Margin="0,0,8,0"/>
                    <Button Content="Очистить список" Style="{StaticResource BtnSecondary}"
                            Command="{Binding ClearCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource BrushSurface1}"
                    BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                    CornerRadius="8" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Исправления к формированию" FontSize="14" FontWeight="Bold"
                               Margin="2,0,0,10"/>
                    <ListBox Grid.Row="1" ItemsSource="{Binding Items}"
                             SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                             BorderThickness="0" Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              VerticalAlignment="Top" Margin="0,2,10,0"
                                              ToolTip="Включить исправление в XML"/>
                                    <StackPanel Grid.Column="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding DocumentNumber}" FontWeight="Bold" FontSize="14"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="1" Text="{Binding CheckCountText}" FontSize="12"
                                                       Foreground="{DynamicResource BrushText3}" Margin="10,1,0,0"/>
                                        </Grid>
                                        <TextBlock Text="{Binding DocumentTypeLabel}" FontSize="12"
                                                   Foreground="{DynamicResource BrushText2}" Margin="0,2,0,0"/>
                                        <TextBlock Text="{Binding ScenarioLabel}" FontSize="12"
                                                   Foreground="{DynamicResource BrushText2}"
                                                   TextWrapping="Wrap" Margin="0,3,0,0"/>
                                        <TextBlock Text="{Binding StateLabel}" FontSize="12" FontWeight="SemiBold"
                                                   Margin="0,7,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource BrushOrange}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsReady}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource BrushAccent2}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsGenerated}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource BrushGreen}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="{DynamicResource BrushSurface1}"
                    BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <TextBlock Text="Выберите исправление слева"
                               FontSize="15" Foreground="{DynamicResource BrushText3}"
                               HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedItem}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="18">
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedItem}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <StackPanel DataContext="{Binding SelectedItem}">
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding DocumentNumber}" FontSize="21" FontWeight="Bold"/>
                                        <TextBlock Foreground="{DynamicResource BrushText2}" Margin="0,3,0,0">
                                            <Run Text="{Binding DocumentTypeLabel, Mode=OneWay}"/><Run Text=" · "/>
                                            <Run Text="{Binding DocumentDate, Mode=OneWay}"/><Run Text=" · "/>
                                            <Run Text="{Binding Department, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                                        <Button Content="Редактировать" Style="{StaticResource BtnSecondary}"
                                                Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" Margin="0,0,8,0"/>
                                        <Button Content="Удалить" Style="{StaticResource BtnSecondary}"
                                                Command="{Binding DataContext.RemoveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </Grid>

                                <Border BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                                        Background="{DynamicResource BrushSurface2}" CornerRadius="7"
                                        Padding="12" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock Text="{Binding StateLabel}" FontWeight="Bold" FontSize="13"/>
                                        <TextBlock Text="{Binding ReadinessMessage}" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource BrushText2}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Сценарий" Style="{StaticResource MetaLabel}"/>
                                        <TextBox Text="{Binding ScenarioLabel, Mode=OneWay}" Style="{StaticResource SelectableValue}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="ФП исходного чека" Style="{StaticResource MetaLabel}"/>
                                        <TextBox Text="{Binding OriginalFiscalNumber, Mode=OneWay}" Style="{StaticResource SelectableValue}"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="Последовательность чеков" FontSize="15" FontWeight="Bold"
                                           Margin="0,0,0,10"/>
                                <ItemsControl ItemsSource="{Binding Steps}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                                                    Background="{DynamicResource BrushSurface2}" CornerRadius="7"
                                                    Padding="14" Margin="0,0,0,10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="44"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="32" Height="32" CornerRadius="6"
                                                            Background="{DynamicResource BrushAccent}"
                                                            VerticalAlignment="Top">
                                                        <TextBlock Text="{Binding Sequence}" Foreground="White"
                                                                   FontWeight="Bold" HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="Bold"/>
                                                        <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource BrushText2}">
                                                            <Run Text="{Binding OperationLabel, Mode=OneWay}" FontWeight="SemiBold"/>
                                                            <Run Text="  ·  "/><Run Text="{Binding PaymentLabel, Mode=OneWay}"/>
                                                            <Run Text="  ·  "/><Run Text="{Binding VatLabel, Mode=OneWay}"/>
                                                        </TextBlock>
                                                        <TextBlock Text="{Binding ItemsText}" FontSize="12"
                                                                   Foreground="{DynamicResource BrushText3}" Margin="0,4,0,0"/>
                                                        <TextBox Text="{Binding Tag1192Text, Mode=OneWay}" Style="{StaticResource SelectableValue}"
                                                                 Foreground="{DynamicResource BrushAccent2}" Margin="0,5,0,0"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2" Text="{Binding AmountText}" FontSize="16"
                                                               FontWeight="Bold" VerticalAlignment="Top" Margin="16,0,0,0"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="Пояснение ошибки" Style="{StaticResource MetaLabel}" Margin="0,6,0,3"/>
                                <TextBox Text="{Binding Notes, Mode=OneWay}" Style="{StaticResource SelectableValue}"
                                         MinHeight="42"/>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3" Background="{DynamicResource BrushSurface1}"
                BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                CornerRadius="8" Padding="14" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock FontSize="13">
                        <Run Text="Выбрано: "/><Run Text="{Binding SelectedCount, Mode=OneWay}" FontWeight="Bold"/>
                        <Run Text=" исправлений · "/><Run Text="{Binding SelectedCheckCount, Mode=OneWay}" FontWeight="Bold"/>
                        <Run Text=" чеков · служебных записок: "/><Run Text="{Binding SelectedCount, Mode=OneWay}" FontWeight="Bold"/>
                    </TextBlock>
                    <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource BrushText2}"
                               FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Width="360" Margin="0,0,12,0">
                        <TextBlock Text="Кассир" Style="{StaticResource MetaLabel}"/>
                        <ComboBox ItemsSource="{Binding AvailableCashiers}"
                                  SelectedItem="{Binding SelectedCashier, Mode=TwoWay}"
                                  MinHeight="36"/>
                    </StackPanel>
                    <CheckBox Content="Один XML" IsChecked="{Binding MergeXml}"
                              VerticalAlignment="Center" Margin="0,0,14,0"/>
                    <Button Content="Сформировать XML и служебки"
                            Style="{StaticResource BtnPrimary}" Padding="18,11"
                            Command="{Binding GenerateCommand}"
                            IsEnabled="{Binding CanGenerate}"
                            ToolTip="Формирует только XML-файлы для ручной загрузки в АТОЛ Online"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
