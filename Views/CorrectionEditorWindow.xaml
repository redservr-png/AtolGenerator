<Window x:Class="AtolGenerator.Views.CorrectionEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:cv="clr-namespace:AtolGenerator.Views.Converters"
        Title="Редактирование коррекции"
        Width="1380" Height="900" MinWidth="1120" MinHeight="740"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize" ShowInTaskbar="False"
        Background="{DynamicResource BrushBg}"
        Foreground="{DynamicResource BrushText}"
        FontFamily="Segoe UI" FontSize="14">

    <Window.Resources>
        <cv:OrderKindLabelConverter             x:Key="KindLabel"/>
        <cv:CorrectionScenarioLabelConverter    x:Key="ScenarioLabel"/>
        <cv:SourceDocumentTypeLabelConverter    x:Key="DocTypeLabel"/>
        <cv:BoolToVisibilityConverter           x:Key="BoolVis"/>
        <cv:VatRateLabelConverter               x:Key="VatLabel"/>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushText2}"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushText}"/>
        </Style>

        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushText3}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="PanelBorder" TargetType="Border" BasedOn="{StaticResource Panel}">
            <Setter Property="Padding" Value="16"/>
        </Style>

        <Style x:Key="SoftPanelBorder" TargetType="Border" BasedOn="{StaticResource PanelBorder}">
            <Setter Property="Background" Value="{DynamicResource BrushSurface2}"/>
        </Style>

        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Background"   Value="{DynamicResource BrushSurface2}"/>
            <Setter Property="Foreground"   Value="{DynamicResource BrushText}"/>
            <Setter Property="BorderBrush"  Value="{DynamicResource BrushBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="10,7"/>
            <Setter Property="FontSize"     Value="14"/>
            <Setter Property="MinHeight"    Value="40"/>
            <Setter Property="CaretBrush"   Value="{DynamicResource BrushAccent}"/>
        </Style>

        <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Background"      Value="{DynamicResource BrushSurface2}"/>
            <Setter Property="Foreground"      Value="{DynamicResource BrushText}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BrushBorder}"/>
            <Setter Property="Padding"         Value="10,7"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="MinHeight"       Value="40"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <Style x:Key="EditorPrimary" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
            <Setter Property="Padding" Value="22,9"/>
        </Style>

        <Style x:Key="EditorGhost" TargetType="Button" BasedOn="{StaticResource BtnGhost}">
            <Setter Property="MinHeight" Value="36"/>
        </Style>

        <Style TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
            <Setter Property="Background" Value="{DynamicResource BrushSurface1}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource BrushBorder}"/>
            <Setter Property="RowBackground" Value="{DynamicResource BrushSurface1}"/>
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource BrushSurface2}"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
        </Style>

        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
            <Setter Property="Background" Value="{DynamicResource BrushSurface2}"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushText2}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}"/>
        </Style>

        <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="28,24,28,22">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Редактирование исправления" Style="{StaticResource PageTitle}"/>
                    <TextBlock Text="Проверьте две стороны исправления: исходный ошибочный чек и правильный чек."
                               Style="{StaticResource PageSubtitle}" Margin="0,4,0,0"/>
                </StackPanel>

                <Border Grid.Column="1" Background="#102563EB" CornerRadius="6"
                        BorderBrush="#332563EB" BorderThickness="1"
                        Padding="10,5" VerticalAlignment="Top">
                    <TextBlock Text="{Binding Kind, Converter={StaticResource KindLabel}}"
                               Foreground="{DynamicResource BrushAccent}"
                               FontSize="12" FontWeight="Bold"/>
                </Border>
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,0,8,0">
                    <Border Style="{StaticResource SoftPanelBorder}" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <TextBlock Text="Тип документа" Style="{StaticResource FieldLabel}"/>
                                <ComboBox x:Name="DocTypeCombo"
                                          ItemsSource="{Binding AllDocumentTypes, RelativeSource={RelativeSource AncestorType=Window}}"
                                          SelectedItem="{Binding DocumentType, Mode=TwoWay}"
                                          SelectionChanged="LayoutMode_SelectionChanged">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Converter={StaticResource DocTypeLabel}}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <TextBlock Text="Сценарий" Style="{StaticResource FieldLabel}"/>
                                <ComboBox x:Name="ScenarioCombo"
                                          ItemsSource="{Binding AllScenarios, RelativeSource={RelativeSource AncestorType=Window}}"
                                          SelectedItem="{Binding CorrectionScenario, Mode=TwoWay}"
                                          SelectionChanged="LayoutMode_SelectionChanged">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Converter={StaticResource ScenarioLabel}}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0">
                                <TextBlock Text="Номер документа" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding OrderNum, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="2">
                                <TextBlock Text="Дата документа" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding OrderDate, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="4" Grid.Column="0">
                                <TextBlock Text="Город / подразделение" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding City, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="4" Grid.Column="2">
                                <TextBlock Text="Покупатель" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding CustomerName, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border x:Name="RepairPairPanel" Margin="0,2,0,14"
                            Visibility="Collapsed">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,12">
                                <Border DockPanel.Dock="Left" Width="4" Height="32"
                                        Background="{DynamicResource BrushOrange}" CornerRadius="2"
                                        Margin="0,0,10,0"/>
                                <StackPanel>
                                    <TextBlock Text="План исправления"
                                               FontSize="16" FontWeight="Bold"
                                               Foreground="{DynamicResource BrushOrange}"/>
                                    <TextBlock Text="Исходная и правильная стороны настраиваются независимо и сохраняются в XML по рассчитанному сценарию."
                                               Style="{StaticResource MutedText}"/>
                                </StackPanel>
                            </DockPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.18*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border x:Name="ReverseSidePanel" Grid.Column="0" Style="{StaticResource SoftPanelBorder}">
                                    <StackPanel>
                                        <TextBlock Text="1. Отмена старого чека" Style="{StaticResource SectionTitle}"/>
                                        <TextBlock Style="{StaticResource MutedText}" Margin="0,3,0,12">
                                            <Run Text="Операция: "/>
                                            <Run Text="{Binding PlannedReverseOperation, Mode=OneWay}" FontWeight="SemiBold"/>
                                            <Run Text=". ФП исходного чека будет записан в тег 1192."/>
                                        </TextBlock>

                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Сумма старого чека, ₽" Style="{StaticResource FieldLabel}"/>
                                                <TextBox Text="{Binding OriginalCheckAmount, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                                                         ToolTip="Итоговая сумма возвратного чека"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="ФП старого чека" Style="{StaticResource FieldLabel}"/>
                                                <TextBox Text="{Binding OriginalFiscalNumber, UpdateSourceTrigger=PropertyChanged}"
                                                         ToolTip="Фискальный признак ошибочного чека"/>
                                            </StackPanel>
                                        </Grid>

                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Ставка НДС старого чека" Style="{StaticResource FieldLabel}"/>
                                                <ComboBox ItemsSource="{Binding AvailableVatRates, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          DisplayMemberPath="Label" SelectedValuePath="Code"
                                                          SelectedValue="{Binding OriginalVatType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          SelectionChanged="OriginalVat_SelectionChanged"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                                                <TextBlock Text="Сумма НДС" Style="{StaticResource FieldLabel}"/>
                                                <TextBlock x:Name="OriginalVatAmountText" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource BrushAccent2}" Margin="2,8,0,8"/>
                                            </StackPanel>
                                        </Grid>

                                        <DockPanel Margin="0,2,0,6">
                                            <TextBlock Text="Табличная часть отмены"
                                                       Style="{StaticResource FieldLabel}"
                                                       DockPanel.Dock="Left"/>
                                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                                <Button Content="Добавить позицию" Style="{StaticResource EditorGhost}"
                                                        Padding="10,5" Margin="0,0,6,0"
                                                        Click="AddOriginalItem_Click"/>
                                                <Button Content="Удалить" Style="{StaticResource EditorGhost}"
                                                        Padding="10,5"
                                                        Click="DeleteOriginalItem_Click"/>
                                            </StackPanel>
                                        </DockPanel>

                                        <DataGrid x:Name="OriginalItemsGrid"
                                                  ItemsSource="{Binding OriginalItems}"
                                                  Height="190"
                                                  CanUserAddRows="False"
                                                  CanUserDeleteRows="False"
                                                  CurrentCellChanged="ItemsGrid_CurrentCellChanged">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Номенклатура"
                                                                    Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                                    Width="*"/>
                                                <DataGridTextColumn Header="Кол-во"
                                                                    Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"
                                                                    Width="90"/>
                                                <DataGridTextColumn Header="Сумма, ₽"
                                                                    Binding="{Binding Sum, UpdateSourceTrigger=PropertyChanged}"
                                                                    Width="110"/>
                                                <DataGridTemplateColumn Header="НДС" Width="145">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding VatType, Converter={StaticResource VatLabel}}" VerticalAlignment="Center"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                    <DataGridTemplateColumn.CellEditingTemplate>
                                                        <DataTemplate>
                                                            <ComboBox ItemsSource="{Binding AvailableVatRates, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                      DisplayMemberPath="Label" SelectedValuePath="Code"
                                                                      SelectedValue="{Binding VatType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                      SelectionChanged="ItemVat_SelectionChanged"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellEditingTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>

                                        <TextBlock x:Name="OriginalItemsTotalText"
                                                   Style="{StaticResource MutedText}"
                                                   Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Border>

                                <Border x:Name="CorrectSidePanel" Grid.Column="2" Style="{StaticResource SoftPanelBorder}">
                                    <StackPanel>
                                        <TextBlock Text="Правильная сторона" Style="{StaticResource SectionTitle}"/>
                                        <TextBlock Style="{StaticResource MutedText}" Margin="0,3,0,12">
                                            <Run Text="Операция: "/>
                                            <Run Text="{Binding PlannedCorrectOperation, Mode=OneWay}" FontWeight="SemiBold"/>
                                            <Run Text=". Если исправляется уже пробитый чек, это обычный чек с тем же тегом 1192."/>
                                        </TextBlock>

                                        <TextBlock Text="Исправленная сумма, ₽" Style="{StaticResource FieldLabel}"/>
                                        <TextBox Text="{Binding CorrectAmount, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                                                 ToolTip="Итог правильного чека после исправления"/>

                                        <Grid Margin="0,12,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Ставка НДС правильного чека" Style="{StaticResource FieldLabel}"/>
                                                <ComboBox ItemsSource="{Binding AvailableVatRates, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          DisplayMemberPath="Label" SelectedValuePath="Code"
                                                          SelectedValue="{Binding CorrectVatType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          SelectionChanged="CorrectVat_SelectionChanged"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                                                <TextBlock Text="Сумма НДС" Style="{StaticResource FieldLabel}"/>
                                                <TextBlock x:Name="CorrectVatAmountText" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource BrushAccent2}" Margin="2,8,0,8"/>
                                            </StackPanel>
                                        </Grid>

                                        <StackPanel x:Name="CorrectItemsPanel" Margin="0,12,0,0">
                                            <DockPanel Margin="0,0,0,6">
                                                <TextBlock Text="Табличная часть правильного чека"
                                                           Style="{StaticResource FieldLabel}"
                                                           DockPanel.Dock="Left"/>
                                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                                    <Button Content="Добавить позицию" Style="{StaticResource EditorGhost}"
                                                            Padding="10,5" Margin="0,0,6,0"
                                                            Click="AddCorrectItem_Click"/>
                                                    <Button Content="Удалить" Style="{StaticResource EditorGhost}"
                                                            Padding="10,5"
                                                            Click="DeleteCorrectItem_Click"/>
                                                </StackPanel>
                                            </DockPanel>

                                            <DataGrid x:Name="CorrectItemsGrid"
                                                      ItemsSource="{Binding Items}"
                                                      Height="190"
                                                      CanUserAddRows="False"
                                                      CanUserDeleteRows="False"
                                                      CurrentCellChanged="ItemsGrid_CurrentCellChanged">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Номенклатура"
                                                                        Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                                        Width="*"/>
                                                    <DataGridTextColumn Header="Кол-во"
                                                                        Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"
                                                                        Width="90"/>
                                                    <DataGridTextColumn Header="Сумма, ₽"
                                                                        Binding="{Binding Sum, UpdateSourceTrigger=PropertyChanged}"
                                                                        Width="110"/>
                                                    <DataGridTemplateColumn Header="НДС" Width="145">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding VatType, Converter={StaticResource VatLabel}}" VerticalAlignment="Center"/>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                        <DataGridTemplateColumn.CellEditingTemplate>
                                                            <DataTemplate>
                                                                <ComboBox ItemsSource="{Binding AvailableVatRates, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                          DisplayMemberPath="Label" SelectedValuePath="Code"
                                                                          SelectedValue="{Binding VatType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                          SelectionChanged="ItemVat_SelectionChanged"/>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellEditingTemplate>
                                                    </DataGridTemplateColumn>
                                                </DataGrid.Columns>
                                            </DataGrid>

                                            <TextBlock x:Name="CorrectItemsTotalText"
                                                       Style="{StaticResource MutedText}"
                                                       Margin="0,8,0,0"/>
                                        </StackPanel>

                                        <TextBlock x:Name="CorrectCorrectionHint"
                                                   Text="Для одиночного чека коррекции ФФД 1.05 табличная часть не передаётся."
                                                   Style="{StaticResource MutedText}"
                                                   Margin="0,12,0,0"/>

                                        <Grid Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Основание: дата" Style="{StaticResource FieldLabel}"/>
                                                <TextBox Text="{Binding CorrectionDate, UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Основание: номер" Style="{StaticResource FieldLabel}"/>
                                                <TextBox Text="{Binding CorrectionNumber, UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                        </Grid>

                                        <Border Background="{DynamicResource BrushSurface1}"
                                                BorderBrush="{DynamicResource BrushBorder}"
                                                BorderThickness="1" CornerRadius="6"
                                                Padding="10" Margin="0,12,0,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="НДС" FontWeight="Bold"
                                                           Foreground="{DynamicResource BrushAccent2}"
                                                           Margin="0,0,12,0"/>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="Ставки задаются отдельно для старого и правильного чека. Ставка строки номенклатуры имеет приоритет над ставкой чека."
                                                               TextWrapping="Wrap"/>
                                                    <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource BrushText2}">
                                                        <Run Text="Правило 1С / агент: "/>
                                                        <Run Text="{Binding AgentVatDisplay, Mode=OneWay}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border x:Name="FallbackDataPanel" Style="{StaticResource SoftPanelBorder}" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <TextBlock Text="Сумма правильная (из 1С), ₽" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding CorrectAmount, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                                         ToolTip="Сумма документа из 1С — используется в чеке коррекции"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <TextBlock Text="Сумма в чеке (ошибочная), ₽" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding OriginalCheckAmount, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                                         ToolTip="Сумма, которая была в ошибочно пробитом чеке"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.ColumnSpan="3">
                                <TextBlock Text="ФП исходного чека" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding OriginalFiscalNumber, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Фискальный признак ошибочного чека из 1С и отчёта ОФД"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SoftPanelBorder}">
                        <StackPanel>
                            <TextBlock Text="Описание / комментарий" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     MinHeight="72"
                                     VerticalScrollBarVisibility="Auto"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                <Button Content="Отмена" Style="{StaticResource EditorGhost}"
                        Margin="0,0,8,0"
                        Click="Cancel_Click"/>
                <Button Content="Сохранить изменения" Style="{StaticResource EditorPrimary}"
                        Click="Save_Click" IsDefault="True"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
