<Window x:Class="AtolGenerator.Views.TaxcomReceiptSearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Поиск чеков в Такскоме"
        Icon="/AtolGenerator;component/Resources/app.ico"
        Width="1440" Height="880"
        MinWidth="1080" MinHeight="680"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BrushBg}"
        Loaded="OnLoaded">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*"/>
      <ColumnDefinition Width="330"/>
    </Grid.ColumnDefinitions>

    <Grid Grid.Column="0">
      <Grid.RowDefinitions>
        <RowDefinition Height="48"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>
      <Border Background="{DynamicResource BrushSurface1}"
              BorderBrush="{DynamicResource BrushBorder}"
              BorderThickness="0,0,1,1">
        <Grid Margin="14,0">
          <TextBlock Text="Такском-Касса · поиск по ФПД"
                     VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold"
                     Foreground="{DynamicResource BrushText}"/>
          <TextBlock x:Name="AddressText" HorizontalAlignment="Right"
                     VerticalAlignment="Center" FontSize="11"
                     Foreground="{DynamicResource BrushText3}"/>
        </Grid>
      </Border>
      <wv2:WebView2 x:Name="Browser" Grid.Row="1" DefaultBackgroundColor="White"/>
    </Grid>

    <Border Grid.Column="1" Background="{DynamicResource BrushSurface1}"
            BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,0,0,0">
      <Grid Margin="20">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="12"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="12"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="16"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="8"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Поиск исходных чеков" FontSize="20" FontWeight="SemiBold"
                   Foreground="{DynamicResource BrushText}"/>
        <TextBlock x:Name="ProgressText" Grid.Row="1" Margin="0,5,0,0"
                   Foreground="{DynamicResource BrushText3}" FontSize="12"/>

        <Border Grid.Row="3" Background="{DynamicResource BrushSurface2}"
                BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                CornerRadius="6" Padding="12">
          <StackPanel>
            <TextBlock Text="Текущий запрос" Foreground="{DynamicResource BrushText3}" FontSize="11"/>
            <TextBlock x:Name="CurrentDocumentText" Margin="0,5,0,0"
                       Foreground="{DynamicResource BrushText2}" FontWeight="SemiBold"
                       TextWrapping="Wrap"/>
            <TextBlock x:Name="CurrentFiscalSignText" Margin="0,4,0,0"
                       Foreground="{DynamicResource BrushAccent}" FontSize="15" FontWeight="SemiBold"/>
          </StackPanel>
        </Border>

        <ListBox x:Name="ResultList" Grid.Row="5"
                 Background="Transparent" BorderThickness="0"
                 Foreground="{DynamicResource BrushText2}"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>

        <TextBlock x:Name="StatusText" Grid.Row="7" TextWrapping="Wrap"
                   Foreground="{DynamicResource BrushText2}" FontSize="12"/>

        <Grid Grid.Row="9">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="8"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <Button x:Name="SearchButton" Content="Продолжить поиск"
                  Style="{StaticResource BtnPrimary}" Padding="14,8"
                  Click="SearchButton_Click"/>
          <Button Grid.Column="2" Content="Закрыть"
                  Style="{StaticResource BtnSecondary}" Padding="14,8"
                  Click="CloseButton_Click"/>
        </Grid>
      </Grid>
    </Border>
  </Grid>
</Window>
